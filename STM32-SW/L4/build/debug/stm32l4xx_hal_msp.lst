 196:Core/Src/stm32l4xx_hal_msp.c **** /**
 197:Core/Src/stm32l4xx_hal_msp.c ****   * @brief UART MSP De-Initialization
 198:Core/Src/stm32l4xx_hal_msp.c ****   * This function freeze the hardware resources used in this example
 199:Core/Src/stm32l4xx_hal_msp.c ****   * @param huart: UART handle pointer
 200:Core/Src/stm32l4xx_hal_msp.c ****   * @retval None
 201:Core/Src/stm32l4xx_hal_msp.c ****   */
