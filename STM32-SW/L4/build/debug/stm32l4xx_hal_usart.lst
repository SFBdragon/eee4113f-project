3253:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****   /* Check that a Tx process is ongoing */
3254:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****   if ((state == HAL_USART_STATE_BUSY_TX) ||
3255:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****       (state == HAL_USART_STATE_BUSY_TX_RX))
3256:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****   {
3257:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     for (nb_tx_data = husart->NbTxDataToProcess ; nb_tx_data > 0U ; nb_tx_data--)
3258:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     {
3259:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****       if (husart->TxXferCount == 0U)
3260:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****       {
