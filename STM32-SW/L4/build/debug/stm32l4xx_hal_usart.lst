3267:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         break; /* force exit loop */
3268:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****       }
3269:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****       else if (__HAL_USART_GET_FLAG(husart, USART_FLAG_TXFNF) == SET)
