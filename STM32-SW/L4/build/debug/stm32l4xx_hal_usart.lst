 668:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** /** @defgroup USART_Exported_Functions_Group2 IO operation functions
 669:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****   * @brief   USART Transmit and Receive functions
 670:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****   *
 671:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** @verbatim
 672:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****  ===============================================================================
 673:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****                       ##### IO operation functions #####
 674:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****  ===============================================================================
 675:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     [..] This subsection provides a set of functions allowing to manage the USART synchronous SPI
 676:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     data transfers.
 677:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** 
 678:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     [..] The USART Synchronous SPI supports master and slave modes (SCLK as output or input).
 679:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** 
 680:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     [..]
 681:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** 
 682:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     (#) There are two modes of transfer:
 683:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) Blocking mode: The communication is performed in polling mode.
 684:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              The HAL status of all data processing is returned by the same function
 685:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              after finishing transfer.
 686:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) No-Blocking mode: The communication is performed using Interrupts
 687:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              or DMA, These API's return the HAL status.
 688:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              The end of the data processing will be indicated through the
 689:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              dedicated USART IRQ when using Interrupt mode or the DMA IRQ when
 690:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              using DMA mode.
 691:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              The HAL_USART_TxCpltCallback(), HAL_USART_RxCpltCallback() and HAL_USART_TxRxCpltCallb
 692:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              will be executed respectively at the end of the transmit or Receive process
 693:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              The HAL_USART_ErrorCallback()user callback will be executed when a communication error
 694:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** 
 695:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     (#) Blocking mode API's are :
 696:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_Transmit() in simplex mode
 697:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_Receive() in full duplex receive only
 698:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_TransmitReceive() in full duplex mode
 699:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** 
 700:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     (#) Non-Blocking mode API's with Interrupt are :
 701:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_Transmit_IT() in simplex mode
 702:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_Receive_IT() in full duplex receive only
 703:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_TransmitReceive_IT() in full duplex mode
 704:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_IRQHandler()
 705:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** 
 706:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     (#) No-Blocking mode API's  with DMA are :
 707:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_Transmit_DMA() in simplex mode
 708:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_Receive_DMA() in full duplex receive only
 709:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_TransmitReceive_DMA() in full duplex mode
 710:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_DMAPause()
 711:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_DMAResume()
 712:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_DMAStop()
 713:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** 
 714:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     (#) A set of Transfer Complete Callbacks are provided in Non_Blocking mode:
ARM GAS  /tmp/cc8mN3FX.s 			page 14


 715:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_TxCpltCallback()
 716:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_RxCpltCallback()
 717:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_TxHalfCpltCallback()
 718:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_RxHalfCpltCallback()
 719:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_ErrorCallback()
 720:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_TxRxCpltCallback()
 721:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** 
 722:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     (#) Non-Blocking mode transfers could be aborted using Abort API's :
 723:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_Abort()
 724:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_Abort_IT()
 725:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** 
 726:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     (#) For Abort services based on interrupts (HAL_USART_Abort_IT), a Abort Complete Callbacks is 
 727:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) HAL_USART_AbortCpltCallback()
 728:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** 
 729:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****     (#) In Non-Blocking mode transfers, possible errors are split into 2 categories.
 730:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         Errors are handled as follows :
 731:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) Error is considered as Recoverable and non blocking : Transfer could go till end, but 
 732:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              to be evaluated by user : this concerns Frame Error,
 733:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              Parity Error or Noise Error in Interrupt mode reception .
 734:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              Received character is then retrieved and stored in Rx buffer, Error code is set to all
 735:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              error type, and HAL_USART_ErrorCallback() user callback is executed.
 736:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              Transfer is kept ongoing on USART side.
 737:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              If user wants to abort it, Abort services should be called by user.
 738:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         (++) Error is considered as Blocking : Transfer could not be completed properly and is abor
 739:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              This concerns Overrun Error In Interrupt mode reception and all errors in DMA mode.
 740:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              Error code is set to allow user to identify error type,
 741:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****              and HAL_USART_ErrorCallback() user callback is executed.
 742:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** 
 743:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** @endverbatim
