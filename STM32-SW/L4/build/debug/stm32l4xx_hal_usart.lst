3262:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c ****         __HAL_USART_DISABLE_IT(husart, USART_IT_TXFT);
3263:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal_usart.c **** 
