 184:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal.c ****     HAL_MspInit();
 185:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal.c ****   }
 186:Drivers/STM32L4xx_HAL_Driver/Src/stm32l4xx_hal.c **** 
