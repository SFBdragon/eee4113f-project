ARM GAS  /tmp/ccQFO4hh.s 			page 5


 203:Core/Src/main.c ****     
 204:Core/Src/main.c ****     // 2. Try to open and READ the existing string
 205:Core/Src/main.c ****     if (f_open(&MyFile, filename, FA_READ) == FR_OK) {
 206:Core/Src/main.c ****         f_read(&MyFile, test_string, 5, &br); // Read first 5 chars
 207:Core/Src/main.c ****         test_string[br] = '\0';               // Null terminate
 208:Core/Src/main.c ****         f_close(&MyFile);
 209:Core/Src/main.c **** 
 210:Core/Src/main.c ****         // 3. MODIFY: Rotate the string (e.g., ABCDE -> BCDEA)
 211:Core/Src/main.c ****         char first = test_string[0];
 212:Core/Src/main.c ****         for(int i = 0; i < 4; i++) {
 213:Core/Src/main.c ****             test_string[i] = test_string[i+1];
 214:Core/Src/main.c ****         }
 215:Core/Src/main.c ****         test_string[4] = first;
 216:Core/Src/main.c ****         
 217:Core/Src/main.c ****         sprintf(oled_msg, "Read: %s", test_string);
 218:Core/Src/main.c ****     } else {
 219:Core/Src/main.c ****         // 4. INITIALIZE: If file doesn't exist, create it with "ABCDE"
 220:Core/Src/main.c ****         strcpy(test_string, "ABCDE");
 221:Core/Src/main.c ****         sprintf(oled_msg, "Init: ABCDE");
 222:Core/Src/main.c ****     }
 223:Core/Src/main.c **** 
 224:Core/Src/main.c ****     // 5. WRITE the modified string back to the card
 225:Core/Src/main.c ****     if (f_open(&MyFile, filename, FA_WRITE | FA_CREATE_ALWAYS) == FR_OK) {
 226:Core/Src/main.c ****         f_write(&MyFile, test_string, 5, &bw);
 227:Core/Src/main.c ****         f_close(&MyFile);
 228:Core/Src/main.c ****     }
 229:Core/Src/main.c **** } else {
 230:Core/Src/main.c ****     sprintf(oled_msg, "Mount Fail");
 231:Core/Src/main.c **** }
 232:Core/Src/main.c **** 
 233:Core/Src/main.c **** // 6. Output to OLED
 234:Core/Src/main.c **** ssd1306_Fill(Black);
 235:Core/Src/main.c **** ssd1306_SetCursor(0, 0);
 236:Core/Src/main.c **** ssd1306_WriteString(oled_msg, Font_7x10, White);
 237:Core/Src/main.c **** ssd1306_UpdateScreen();
 238:Core/Src/main.c **** 
