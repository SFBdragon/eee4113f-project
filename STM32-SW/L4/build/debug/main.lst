 464:Core/Src/main.c **** 
 465:Core/Src/main.c ****           // SLIP DECODE
 466:Core/Src/main.c ****           // SLIP special bytes:
 467:Core/Src/main.c ****           //   END     = 0xC0  -- marks start/end of packet
 468:Core/Src/main.c ****           //   ESC     = 0xDB  -- escape next byte
 469:Core/Src/main.c ****           //   ESC_END = 0xDC  -- escaped END (ESC + ESC_END => 0xC0)
 470:Core/Src/main.c ****           //   ESC_ESC = 0xDD  -- escaped ESC (ESC + ESC_ESC => 0xDB)
 471:Core/Src/main.c **** 
 472:Core/Src/main.c ****           #define SLIP_END     0xC0
 473:Core/Src/main.c ****           #define SLIP_ESC     0xDB
 474:Core/Src/main.c ****           #define SLIP_ESC_END 0xDC
 475:Core/Src/main.c ****           #define SLIP_ESC_ESC 0xDD
 476:Core/Src/main.c ****           #define SLIP_MAX_PACKET 250
 477:Core/Src/main.c **** 
 478:Core/Src/main.c ****           static uint8_t slip_buf[SLIP_MAX_PACKET];
 479:Core/Src/main.c ****           uint16_t slip_len = 0;
 480:Core/Src/main.c ****           uint8_t in_esc = 0;
 481:Core/Src/main.c ****           uint8_t slip_err = 0;
 482:Core/Src/main.c **** 
 483:Core/Src/main.c ****           for (uint16_t i = 0; i < lora_rx_len; i++) {
 484:Core/Src/main.c ****               uint8_t b = lora_rx_buf[i];
 485:Core/Src/main.c **** 
 486:Core/Src/main.c ****               if (b == SLIP_END) {
 487:Core/Src/main.c ****                   // END byte: if we have accumulated bytes, dispatch the packet
ARM GAS  /tmp/ccr1SFtY.s 			page 10


 488:Core/Src/main.c ****                   if (slip_len > 0) {
 489:Core/Src/main.c ****                       recv_lora_packet(slip_buf, (BufLen)slip_len);
 490:Core/Src/main.c ****                       //UART_SendString(&huart3, "JUST EXECUTED: \r\n");
 491:Core/Src/main.c ****                       slip_len = 0;
 492:Core/Src/main.c ****                       in_esc  = 0;
 493:Core/Src/main.c ****                       slip_err = 0;
 494:Core/Src/main.c ****                   }
 495:Core/Src/main.c ****                   // else: leading/trailing END byte, ignore (valid per RFC 1055)
 496:Core/Src/main.c ****               } else if (b == SLIP_ESC) {
 497:Core/Src/main.c ****                   in_esc = 1;
 498:Core/Src/main.c ****               } else if (in_esc) {
 499:Core/Src/main.c ****                   in_esc = 0;
 500:Core/Src/main.c ****                   if      (b == SLIP_ESC_END) b = SLIP_END;
 501:Core/Src/main.c ****                   else if (b == SLIP_ESC_ESC) b = SLIP_ESC;
 502:Core/Src/main.c ****                   else {
 503:Core/Src/main.c ****                       // Protocol violation — discard this packet
 504:Core/Src/main.c ****                       UART_SendString(&huart3, "SLIP ERR: bad escape\r\n");
 505:Core/Src/main.c ****                       slip_err = 1;
 506:Core/Src/main.c ****                       slip_len = 0;
 507:Core/Src/main.c ****                   }
 508:Core/Src/main.c ****                   if (!slip_err) {
 509:Core/Src/main.c ****                       if (slip_len < SLIP_MAX_PACKET) slip_buf[slip_len++] = b;
 510:Core/Src/main.c ****                       else {
 511:Core/Src/main.c ****                           UART_SendString(&huart3, "SLIP ERR: overflow\r\n");
 512:Core/Src/main.c ****                           slip_len = 0;
 513:Core/Src/main.c ****                           slip_err = 1;
 514:Core/Src/main.c ****                       }
 515:Core/Src/main.c ****                   }
 516:Core/Src/main.c ****               } else {
 517:Core/Src/main.c ****                   if (slip_len < SLIP_MAX_PACKET) slip_buf[slip_len++] = b;
 518:Core/Src/main.c ****                   else {
 519:Core/Src/main.c ****                       UART_SendString(&huart3, "SLIP ERR: overflow\r\n");
 520:Core/Src/main.c ****                       slip_len = 0;
 521:Core/Src/main.c ****                       slip_err = 1;
 522:Core/Src/main.c ****                   }
 523:Core/Src/main.c ****               }
 524:Core/Src/main.c ****           }
 525:Core/Src/main.c **** 
 526:Core/Src/main.c ****           // RESET BUFFER WHEN DONE
 527:Core/Src/main.c ****           lora_rx_len = 0;
 528:Core/Src/main.c ****           memset(lora_rx_buf, 0, sizeof(lora_rx_buf));
 529:Core/Src/main.c ****       }
