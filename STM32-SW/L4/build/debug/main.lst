1724:Core/Src/main.c **** void flush_block_buffer_to_disk(void) {
1725:Core/Src/main.c ****     // How many bytes are in the current half that haven't been written yet
1726:Core/Src/main.c ****     uint16_t remaining = rx_write_pos % (RX_BUF_SIZE / 2);
1727:Core/Src/main.c **** 
1728:Core/Src/main.c ****     if (remaining == 0) {
1729:Core/Src/main.c ****         UART_SendString(&huart3, "Flush: nothing to flush\r\n");
1730:Core/Src/main.c ****         return;
1731:Core/Src/main.c ****     }
1732:Core/Src/main.c **** 
1733:Core/Src/main.c ****     char dbg[64];
1734:Core/Src/main.c ****     snprintf(dbg, sizeof(dbg), "Flushing %d remaining bytes\r\n", remaining);
1735:Core/Src/main.c ****     UART_SendString(&huart3, dbg);
1736:Core/Src/main.c **** 
1737:Core/Src/main.c ****     // Determine which half we're currently in
1738:Core/Src/main.c ****     uint8_t *src = (rx_write_pos < (RX_BUF_SIZE / 2))
1739:Core/Src/main.c ****                     ? rxBuffer                        // first half
1740:Core/Src/main.c ****                     : rxBuffer + (RX_BUF_SIZE / 2);  // second half
1741:Core/Src/main.c **** 
1742:Core/Src/main.c ****     // Pack and write only the remaining bytes
1743:Core/Src/main.c ****     PackBlocks(src, remaining);
1744:Core/Src/main.c **** 
1745:Core/Src/main.c ****     HAL_SD_DeInit(&hsd1);
1746:Core/Src/main.c ****     MX_SDMMC1_SD_Init();
1747:Core/Src/main.c **** 
1748:Core/Src/main.c ****     for (uint16_t i = 0; i < NUM_BLOCKS; i++) {
1749:Core/Src/main.c ****         SD_Stream_WriteBlock(packedBlocks[i]);
1750:Core/Src/main.c ****     }
1751:Core/Src/main.c **** 
1752:Core/Src/main.c ****     rx_write_pos = 0;  // reset after flush
1753:Core/Src/main.c ****     UART_SendString(&huart3, "Flush complete\r\n");
1754:Core/Src/main.c **** }
