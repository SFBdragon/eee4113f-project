1687:Core/Src/main.c **** void PackBlocks(const uint8_t *src, uint16_t dataLen) {
1688:Core/Src/main.c ****     // Determine how many bytes go into each block based on total dataLen
1689:Core/Src/main.c ****     uint16_t remaining = dataLen;
1690:Core/Src/main.c **** 
1691:Core/Src/main.c ****     for (uint16_t i = 0; i < NUM_BLOCKS; i++) {
1692:Core/Src/main.c ****         uint8_t *block = packedBlocks[i];
1693:Core/Src/main.c ****         const uint8_t *data = src + (i * BLOCK_DATA_SIZE);
1694:Core/Src/main.c ****         
1695:Core/Src/main.c ****         // Calculate length for THIS specific block
1696:Core/Src/main.c ****         uint16_t currentBlockLen = (remaining > BLOCK_DATA_SIZE) ? BLOCK_DATA_SIZE : remaining;
1697:Core/Src/main.c ****         
1698:Core/Src/main.c ****         // Calculate CRC only for the actual data present in this block
1699:Core/Src/main.c ****         uint16_t crc = crc16(data, currentBlockLen);
1700:Core/Src/main.c **** 
1701:Core/Src/main.c ****         // --- NEW HEADER STRUCTURE ---
1702:Core/Src/main.c ****         // Byte 0-1: Block Length (High byte, then Low byte)
1703:Core/Src/main.c ****         block[0] = (currentBlockLen >> 8) & 0xFF; 
1704:Core/Src/main.c ****         block[1] =  currentBlockLen       & 0xFF; 
1705:Core/Src/main.c ****         
1706:Core/Src/main.c ****         // Byte 2-3: CRC of the data
1707:Core/Src/main.c ****         block[2] = (crc >> 8) & 0xFF;
1708:Core/Src/main.c ****         block[3] =  crc            & 0xFF;
1709:Core/Src/main.c **** 
1710:Core/Src/main.c ****         // Write data
1711:Core/Src/main.c ****         if (currentBlockLen > 0) {
1712:Core/Src/main.c ****             memcpy(&block[4], data, currentBlockLen);
1713:Core/Src/main.c ****         }
1714:Core/Src/main.c **** 
1715:Core/Src/main.c ****         // Optional: Zero out the rest of the 512-byte block if currentBlockLen < BLOCK_DATA_SIZE
1716:Core/Src/main.c ****         if (currentBlockLen < BLOCK_DATA_SIZE) {
1717:Core/Src/main.c ****             memset(&block[4 + currentBlockLen], 0, BLOCK_DATA_SIZE - currentBlockLen);
1718:Core/Src/main.c ****         }
1719:Core/Src/main.c **** 
1720:Core/Src/main.c ****         // Update remaining count
1721:Core/Src/main.c ****         if (remaining >= currentBlockLen) {
1722:Core/Src/main.c ****             remaining -= currentBlockLen;
1723:Core/Src/main.c ****         } else {
1724:Core/Src/main.c ****             remaining = 0;
1725:Core/Src/main.c ****         }
1726:Core/Src/main.c **** 
1727:Core/Src/main.c **** 
1728:Core/Src/main.c ****       
1729:Core/Src/main.c ****     }
1730:Core/Src/main.c **** }
