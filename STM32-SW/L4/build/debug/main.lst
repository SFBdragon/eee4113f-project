1916:Core/Src/main.c **** // TRACK THREE POINTERS - SHAUNS EXPLANATION
1917:Core/Src/main.c **** // READABLE BLOCKS (ZERO) 0-16gb zZER
1918:Core/Src/main.c **** // First wrap around, start incrementing (write head pushes read ahead of it)
1919:Core/Src/main.c **** // if write_head = read_head, read+head++
1920:Core/Src/main.c **** 
1921:Core/Src/main.c **** // PROTECTED HEAD
1922:Core/Src/main.c **** // WORKS LIKE READABLE, INCREMENT THE SAME WAY. 
1923:Core/Src/main.c **** // HEAD ALWAYS BETWEEN
1924:Core/Src/main.c **** // IF WRITE HEAD ABOUT TO HIT PROTECTED, CHECK OVERWRITE POLICY
1925:Core/Src/main.c **** // IF OVERWRITE POLICY IS DISCARD - DISCARD NEW DATA
1926:Core/Src/main.c **** 
1927:Core/Src/main.c **** // FOLLOWING IS IMPLEMENTED IN SD_STREAM.C
1928:Core/Src/main.c **** 
