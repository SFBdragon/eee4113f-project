 832:Core/Src/main.c **** // Direct SDMMC write/read-back test — no FatFS involved
 833:Core/Src/main.c **** void SD_RawWriteTest(void) {
 834:Core/Src/main.c ****     char uart[64];
 835:Core/Src/main.c **** 
 836:Core/Src/main.c ****     // Fill write buffer with known pattern
ARM GAS  /tmp/ccWhmm1O.s 			page 25


 837:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
 838:Core/Src/main.c ****         writeBuf[i] = (uint8_t)(i & 0xFF);
 839:Core/Src/main.c ****     }
 840:Core/Src/main.c ****     memset(readBuf, 0xAA, sizeof(readBuf)); // fill read buf with garbage first
 841:Core/Src/main.c **** 
 842:Core/Src/main.c ****     UART_SendString(&huart3, "\r\n--- RAW HAL SD TEST ---\r\n");
 843:Core/Src/main.c **** 
 844:Core/Src/main.c ****     // --- WRITE ---
 845:Core/Src/main.c ****     HAL_StatusTypeDef wStat = HAL_SD_WriteBlocks(&hsd1, writeBuf, 100, 1, 5000);
 846:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "WriteBlocks: %s (%d)\r\n",
 847:Core/Src/main.c ****              wStat == HAL_OK ? "HAL_OK" : "FAILED", wStat);
 848:Core/Src/main.c ****     UART_SendString(&huart3, uart);
 849:Core/Src/main.c **** 
 850:Core/Src/main.c ****     if (wStat != HAL_OK) {
 851:Core/Src/main.c ****         // Dump SD error state for more detail
 852:Core/Src/main.c ****         HAL_SD_CardStateTypeDef state = HAL_SD_GetCardState(&hsd1);
 853:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "Card state after write: %d\r\n", (int)state);
 854:Core/Src/main.c ****         UART_SendString(&huart3, uart);
 855:Core/Src/main.c **** 
 856:Core/Src/main.c ****         uint32_t sdErr = hsd1.ErrorCode;    // FAILS WITH SDMMC_ERROR_CMD_CRC_FAIL implying signal 
 857:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "SD ErrorCode: 0x%08lX\r\n", (unsigned long)sdErr);
 858:Core/Src/main.c ****         UART_SendString(&huart3, uart);
 859:Core/Src/main.c ****         return;
 860:Core/Src/main.c ****     }
 861:Core/Src/main.c **** 
 862:Core/Src/main.c **** 
 863:Core/Src/main.c ****     // --- WAIT for card to finish ---
 864:Core/Src/main.c ****     uint32_t t = HAL_GetTick();
 865:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
 866:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
 867:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after write!\r\n");
 868:Core/Src/main.c ****             return;
 869:Core/Src/main.c ****         }
 870:Core/Src/main.c ****     }
 871:Core/Src/main.c ****     UART_SendString(&huart3, "Card ready after write.\r\n");
 872:Core/Src/main.c **** 
 873:Core/Src/main.c ****     // --- READ BACK ---
 874:Core/Src/main.c ****     HAL_StatusTypeDef rStat = HAL_SD_ReadBlocks(&hsd1, readBuf, 100, 1, 2000);
 875:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "ReadBlocks:  %s (%d)\r\n",
 876:Core/Src/main.c ****              rStat == HAL_OK ? "HAL_OK" : "FAILED", rStat);
 877:Core/Src/main.c ****     UART_SendString(&huart3, uart);
 878:Core/Src/main.c **** 
 879:Core/Src/main.c ****     if (rStat != HAL_OK) return;
 880:Core/Src/main.c **** 
 881:Core/Src/main.c ****     // Wait for card again
 882:Core/Src/main.c ****     t = HAL_GetTick();
 883:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
 884:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
 885:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after read!\r\n");
 886:Core/Src/main.c ****             return;
 887:Core/Src/main.c ****         }
 888:Core/Src/main.c ****     }
 889:Core/Src/main.c **** 
 890:Core/Src/main.c ****     // --- VERIFY ---
 891:Core/Src/main.c ****     int mismatches = 0;
 892:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
 893:Core/Src/main.c ****         if (readBuf[i] != writeBuf[i]) mismatches++;
ARM GAS  /tmp/ccWhmm1O.s 			page 26


 894:Core/Src/main.c ****     }
 895:Core/Src/main.c **** 
 896:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "Verify: %s (%d mismatches)\r\n",
 897:Core/Src/main.c ****              mismatches == 0 ? "PASS" : "FAIL", mismatches);
 898:Core/Src/main.c ****     UART_SendString(&huart3, uart);
 899:Core/Src/main.c ****     UART_SendString(&huart3, "--- END RAW TEST ---\r\n\r\n");
 900:Core/Src/main.c **** }
