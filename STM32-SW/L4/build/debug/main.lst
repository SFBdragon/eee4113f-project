1416:Core/Src/main.c **** void PackBlocks(const uint8_t *src, uint16_t dataLen) {
1417:Core/Src/main.c ****     // Determine how many bytes go into each block based on total dataLen
1418:Core/Src/main.c ****     uint16_t remaining = dataLen;
