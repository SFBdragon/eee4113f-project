1393:Core/Src/main.c **** void PackBlocks(const uint8_t *src, uint16_t dataLen) {
1394:Core/Src/main.c ****     // Determine how many bytes go into each block based on total dataLen
1395:Core/Src/main.c ****     uint16_t remaining = dataLen;
1396:Core/Src/main.c **** 
