1482:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1483:Core/Src/main.c ****         return;
1484:Core/Src/main.c ****     }
1485:Core/Src/main.c **** 
1486:Core/Src/main.c **** 
1487:Core/Src/main.c ****     // --- WAIT for card to finish ---
1488:Core/Src/main.c ****     uint32_t t = HAL_GetTick();
1489:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1490:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1491:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after write!\r\n");
1492:Core/Src/main.c ****             return;
1493:Core/Src/main.c ****         }
1494:Core/Src/main.c ****     }
1495:Core/Src/main.c ****     UART_SendString(&huart3, "Card ready after write.\r\n");
1496:Core/Src/main.c **** 
