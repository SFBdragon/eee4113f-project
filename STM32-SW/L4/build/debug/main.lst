1425:Core/Src/main.c ****         uint8_t *block = packedBlocks[i];
1426:Core/Src/main.c ****         const uint8_t *data = src + (i * BLOCK_DATA_SIZE);
1427:Core/Src/main.c ****         
1428:Core/Src/main.c ****         // Calculate length for THIS specific block
1429:Core/Src/main.c ****         uint16_t currentBlockLen = (remaining > BLOCK_DATA_SIZE) ? BLOCK_DATA_SIZE : remaining;
1430:Core/Src/main.c ****         
1431:Core/Src/main.c ****         // Calculate CRC only for the actual data present in this block
1432:Core/Src/main.c ****         uint16_t crc = CRC16(data, currentBlockLen);
1433:Core/Src/main.c **** 
1434:Core/Src/main.c ****         // --- NEW HEADER STRUCTURE ---
1435:Core/Src/main.c ****         // Byte 0-1: Block Length (High byte, then Low byte)
1436:Core/Src/main.c ****         block[0] = (currentBlockLen >> 8) & 0xFF; 
1437:Core/Src/main.c ****         block[1] =  currentBlockLen       & 0xFF; 
1438:Core/Src/main.c ****         
1439:Core/Src/main.c ****         // Byte 2-3: CRC of the data
1440:Core/Src/main.c ****         block[2] = (crc >> 8) & 0xFF;
1441:Core/Src/main.c ****         block[3] =  crc            & 0xFF;
1442:Core/Src/main.c **** 
1443:Core/Src/main.c ****         // Write data
1444:Core/Src/main.c ****         if (currentBlockLen > 0) {
1445:Core/Src/main.c ****             memcpy(&block[4], data, currentBlockLen);
1446:Core/Src/main.c ****         }
1447:Core/Src/main.c **** 
1448:Core/Src/main.c ****         // Optional: Zero out the rest of the 512-byte block if currentBlockLen < BLOCK_DATA_SIZE
1449:Core/Src/main.c ****         if (currentBlockLen < BLOCK_DATA_SIZE) {
1450:Core/Src/main.c ****             memset(&block[4 + currentBlockLen], 0, BLOCK_DATA_SIZE - currentBlockLen);
1451:Core/Src/main.c ****         }
1452:Core/Src/main.c **** 
1453:Core/Src/main.c ****         // Update remaining count
1454:Core/Src/main.c ****         if (remaining >= currentBlockLen) {
1455:Core/Src/main.c ****             remaining -= currentBlockLen;
1456:Core/Src/main.c ****         } else {
1457:Core/Src/main.c ****             remaining = 0;
1458:Core/Src/main.c ****         }
1459:Core/Src/main.c **** 
