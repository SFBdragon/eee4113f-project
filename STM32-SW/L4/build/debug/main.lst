1473:Core/Src/main.c **** void PackBlocks(const uint8_t *src, uint16_t dataLen) {
1474:Core/Src/main.c ****     // Determine how many bytes go into each block based on total dataLen
1475:Core/Src/main.c ****     uint16_t remaining = dataLen;
1476:Core/Src/main.c **** 
1477:Core/Src/main.c ****     for (uint16_t i = 0; i < NUM_BLOCKS; i++) {
1478:Core/Src/main.c ****         uint8_t *block = packedBlocks[i];
1479:Core/Src/main.c ****         const uint8_t *data = src + (i * BLOCK_DATA_SIZE);
1480:Core/Src/main.c ****         
1481:Core/Src/main.c ****         // Calculate length for THIS specific block
1482:Core/Src/main.c ****         uint16_t currentBlockLen = (remaining > BLOCK_DATA_SIZE) ? BLOCK_DATA_SIZE : remaining;
1483:Core/Src/main.c ****         
1484:Core/Src/main.c ****         // Calculate CRC only for the actual data present in this block
1485:Core/Src/main.c ****         uint16_t crc = crc16(data, currentBlockLen);
ARM GAS  /tmp/cc1Ioj8q.s 			page 85


1486:Core/Src/main.c **** 
1487:Core/Src/main.c ****         // --- NEW HEADER STRUCTURE ---
1488:Core/Src/main.c ****         // Byte 0-1: Block Length (High byte, then Low byte)
1489:Core/Src/main.c ****         block[0] = (currentBlockLen >> 8) & 0xFF; 
1490:Core/Src/main.c ****         block[1] =  currentBlockLen       & 0xFF; 
1491:Core/Src/main.c ****         
1492:Core/Src/main.c ****         // Byte 2-3: CRC of the data
1493:Core/Src/main.c ****         block[2] = (crc >> 8) & 0xFF;
1494:Core/Src/main.c ****         block[3] =  crc            & 0xFF;
1495:Core/Src/main.c **** 
1496:Core/Src/main.c ****         // Write data
1497:Core/Src/main.c ****         if (currentBlockLen > 0) {
1498:Core/Src/main.c ****             memcpy(&block[4], data, currentBlockLen);
1499:Core/Src/main.c ****         }
1500:Core/Src/main.c **** 
1501:Core/Src/main.c ****         // Optional: Zero out the rest of the 512-byte block if currentBlockLen < BLOCK_DATA_SIZE
1502:Core/Src/main.c ****         if (currentBlockLen < BLOCK_DATA_SIZE) {
1503:Core/Src/main.c ****             memset(&block[4 + currentBlockLen], 0, BLOCK_DATA_SIZE - currentBlockLen);
1504:Core/Src/main.c ****         }
1505:Core/Src/main.c **** 
1506:Core/Src/main.c ****         // Update remaining count
1507:Core/Src/main.c ****         if (remaining >= currentBlockLen) {
1508:Core/Src/main.c ****             remaining -= currentBlockLen;
1509:Core/Src/main.c ****         } else {
1510:Core/Src/main.c ****             remaining = 0;
1511:Core/Src/main.c ****         }
1512:Core/Src/main.c **** 
1513:Core/Src/main.c **** 
1514:Core/Src/main.c ****       
1515:Core/Src/main.c ****     }
1516:Core/Src/main.c **** }
