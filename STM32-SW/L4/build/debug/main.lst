 331:Core/Src/main.c **** 
 332:Core/Src/main.c **** // DEBIGGING SHARC RX:
 333:Core/Src/main.c ****     while (0)
 334:Core/Src/main.c ****     {
 335:Core/Src/main.c ****         uint8_t byte;
 336:Core/Src/main.c ****         if (HAL_UART_Receive(&huart1, &byte, 1, 100) == HAL_OK)
 337:Core/Src/main.c ****         {
 338:Core/Src/main.c ****             HAL_UART_Transmit(&huart3, &byte, 1, 100); // print as ASCII directly
 339:Core/Src/main.c ****             if (byte == 'Z')
 340:Core/Src/main.c ****                 UART_SendString(&huart3, "\r\n");       // newline after every full A-Z cycle
 341:Core/Src/main.c ****         }
 342:Core/Src/main.c ****     }
 343:Core/Src/main.c **** 
 344:Core/Src/main.c ****   while (1)
 345:Core/Src/main.c ****   { 
 346:Core/Src/main.c ****     /*
 347:Core/Src/main.c ****     // WIFI TESST RECIEVE:
 348:Core/Src/main.c ****     uint8_t wi_rxBuffer[20]; 
 349:Core/Src/main.c ****     HAL_StatusTypeDef rxStatus = HAL_UART_Receive(&huart2, wi_rxBuffer, 10, 1000);
 350:Core/Src/main.c ****       if (rxStatus == HAL_OK) {
 351:Core/Src/main.c ****       UART_SendString(&huart3, "WIFI DATA RECEIVED:\r\n"); 
 352:Core/Src/main.c ****       
 353:Core/Src/main.c ****       char hex[8];
 354:Core/Src/main.c ****       for (uint16_t i = 0; i < 10; i++) // 10 is the number of bytes we asked for
 355:Core/Src/main.c ****       {
 356:Core/Src/main.c ****           snprintf(hex, sizeof(hex), "%02X ", wi_rxBuffer[i]);
 357:Core/Src/main.c ****           UART_SendString(&huart3, hex);
 358:Core/Src/main.c ****       }
 359:Core/Src/main.c ****       UART_SendString(&huart3, "\r\n");
