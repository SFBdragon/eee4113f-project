1521:Core/Src/main.c **** void PackBlocks(const uint8_t *src, uint16_t dataLen) {
1522:Core/Src/main.c ****     // Determine how many bytes go into each block based on total dataLen
1523:Core/Src/main.c ****     uint16_t remaining = dataLen;
1524:Core/Src/main.c **** 
1525:Core/Src/main.c ****     for (uint16_t i = 0; i < NUM_BLOCKS; i++) {
1526:Core/Src/main.c ****         uint8_t *block = packedBlocks[i];
1527:Core/Src/main.c ****         const uint8_t *data = src + (i * BLOCK_DATA_SIZE);
1528:Core/Src/main.c ****         
1529:Core/Src/main.c ****         // Calculate length for THIS specific block
1530:Core/Src/main.c ****         uint16_t currentBlockLen = (remaining > BLOCK_DATA_SIZE) ? BLOCK_DATA_SIZE : remaining;
1531:Core/Src/main.c ****         
1532:Core/Src/main.c ****         // Calculate CRC only for the actual data present in this block
1533:Core/Src/main.c ****         uint16_t crc = crc16(data, currentBlockLen);
1534:Core/Src/main.c **** 
1535:Core/Src/main.c ****         // --- NEW HEADER STRUCTURE ---
1536:Core/Src/main.c ****         // Byte 0-1: Block Length (High byte, then Low byte)
1537:Core/Src/main.c ****         block[0] = (currentBlockLen >> 8) & 0xFF; 
1538:Core/Src/main.c ****         block[1] =  currentBlockLen       & 0xFF; 
1539:Core/Src/main.c ****         
1540:Core/Src/main.c ****         // Byte 2-3: CRC of the data
1541:Core/Src/main.c ****         block[2] = (crc >> 8) & 0xFF;
1542:Core/Src/main.c ****         block[3] =  crc            & 0xFF;
1543:Core/Src/main.c **** 
1544:Core/Src/main.c ****         // Write data
1545:Core/Src/main.c ****         if (currentBlockLen > 0) {
1546:Core/Src/main.c ****             memcpy(&block[4], data, currentBlockLen);
1547:Core/Src/main.c ****         }
1548:Core/Src/main.c **** 
1549:Core/Src/main.c ****         // Optional: Zero out the rest of the 512-byte block if currentBlockLen < BLOCK_DATA_SIZE
1550:Core/Src/main.c ****         if (currentBlockLen < BLOCK_DATA_SIZE) {
1551:Core/Src/main.c ****             memset(&block[4 + currentBlockLen], 0, BLOCK_DATA_SIZE - currentBlockLen);
1552:Core/Src/main.c ****         }
1553:Core/Src/main.c **** 
1554:Core/Src/main.c ****         // Update remaining count
1555:Core/Src/main.c ****         if (remaining >= currentBlockLen) {
1556:Core/Src/main.c ****             remaining -= currentBlockLen;
1557:Core/Src/main.c ****         } else {
1558:Core/Src/main.c ****             remaining = 0;
1559:Core/Src/main.c ****         }
1560:Core/Src/main.c **** 
