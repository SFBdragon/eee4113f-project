1465:Core/Src/main.c **** // Direct SDMMC write/read-back test — no FatFS involved
1466:Core/Src/main.c **** void SD_RawWriteTest(void) {
1467:Core/Src/main.c ****     char uart[64];
1468:Core/Src/main.c **** 
1469:Core/Src/main.c ****     // Fill write buffer with known pattern
1470:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
1471:Core/Src/main.c ****         writeBuf[i] = (uint8_t)(i & 0xFF);
1472:Core/Src/main.c ****     }
1473:Core/Src/main.c ****     memset(readBuf, 0xAA, sizeof(readBuf)); // fill read buf with garbage first
1474:Core/Src/main.c **** 
1475:Core/Src/main.c ****     UART_SendString(&huart3, "\r\n--- RAW HAL SD TEST ---\r\n");
1476:Core/Src/main.c **** 
1477:Core/Src/main.c ****     // --- WRITE ---
1478:Core/Src/main.c ****     HAL_StatusTypeDef wStat = HAL_SD_WriteBlocks(&hsd1, writeBuf, 100, 1, 5000);
1479:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "WriteBlocks: %s (%d)\r\n",
1480:Core/Src/main.c ****              wStat == HAL_OK ? "HAL_OK" : "FAILED", wStat);
1481:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1482:Core/Src/main.c **** 
1483:Core/Src/main.c ****     if (wStat != HAL_OK) {
1484:Core/Src/main.c ****         // Dump SD error state for more detail
1485:Core/Src/main.c ****         HAL_SD_CardStateTypeDef state = HAL_SD_GetCardState(&hsd1);
1486:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "Card state after write: %d\r\n", (int)state);
1487:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1488:Core/Src/main.c **** 
1489:Core/Src/main.c ****         uint32_t sdErr = hsd1.ErrorCode;    // FAILS WITH SDMMC_ERROR_CMD_CRC_FAIL implying signal 
1490:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "SD ErrorCode: 0x%08lX\r\n", (unsigned long)sdErr);
1491:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1492:Core/Src/main.c ****         return;
1493:Core/Src/main.c ****     }
1494:Core/Src/main.c **** 
1495:Core/Src/main.c **** 
1496:Core/Src/main.c ****     // --- WAIT for card to finish ---
1497:Core/Src/main.c ****     uint32_t t = HAL_GetTick();
1498:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1499:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1500:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after write!\r\n");
1501:Core/Src/main.c ****             return;
1502:Core/Src/main.c ****         }
1503:Core/Src/main.c ****     }
1504:Core/Src/main.c ****     UART_SendString(&huart3, "Card ready after write.\r\n");
1505:Core/Src/main.c **** 
1506:Core/Src/main.c ****     // --- READ BACK ---
1507:Core/Src/main.c ****     HAL_StatusTypeDef rStat = HAL_SD_ReadBlocks(&hsd1, readBuf, 100, 1, 2000);
1508:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "ReadBlocks:  %s (%d)\r\n",
1509:Core/Src/main.c ****              rStat == HAL_OK ? "HAL_OK" : "FAILED", rStat);
1510:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1511:Core/Src/main.c **** 
1512:Core/Src/main.c ****     if (rStat != HAL_OK) return;
1513:Core/Src/main.c **** 
1514:Core/Src/main.c ****     // Wait for card again
ARM GAS  /tmp/ccr1SFtY.s 			page 37


1515:Core/Src/main.c ****     t = HAL_GetTick();
1516:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1517:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1518:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after read!\r\n");
1519:Core/Src/main.c ****             return;
1520:Core/Src/main.c ****         }
1521:Core/Src/main.c ****     }
1522:Core/Src/main.c **** 
1523:Core/Src/main.c ****     // --- VERIFY ---
1524:Core/Src/main.c ****     int mismatches = 0;
1525:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
1526:Core/Src/main.c ****         if (readBuf[i] != writeBuf[i]) mismatches++;
1527:Core/Src/main.c ****     }
1528:Core/Src/main.c **** 
1529:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "Verify: %s (%d mismatches)\r\n",
1530:Core/Src/main.c ****              mismatches == 0 ? "PASS" : "FAIL", mismatches);
1531:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1532:Core/Src/main.c ****     UART_SendString(&huart3, "--- END RAW TEST ---\r\n\r\n");
1533:Core/Src/main.c **** }
