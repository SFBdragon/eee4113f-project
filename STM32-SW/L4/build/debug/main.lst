1499:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "ReadBlocks:  %s (%d)\r\n",
1500:Core/Src/main.c ****              rStat == HAL_OK ? "HAL_OK" : "FAILED", rStat);
1501:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1502:Core/Src/main.c **** 
1503:Core/Src/main.c ****     if (rStat != HAL_OK) return;
1504:Core/Src/main.c **** 
1505:Core/Src/main.c ****     // Wait for card again
1506:Core/Src/main.c ****     t = HAL_GetTick();
1507:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1508:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1509:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after read!\r\n");
1510:Core/Src/main.c ****             return;
