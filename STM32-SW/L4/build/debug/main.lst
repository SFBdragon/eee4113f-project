1717:Core/Src/main.c **** void PackBlocks(const uint8_t *src, uint16_t dataLen) {
1718:Core/Src/main.c ****     // Determine how many bytes go into each block based on total dataLen
1719:Core/Src/main.c ****     uint16_t remaining = dataLen;
1720:Core/Src/main.c **** 
1721:Core/Src/main.c ****     for (uint16_t i = 0; i < NUM_BLOCKS; i++) {
1722:Core/Src/main.c ****         uint8_t *block = packedBlocks[i];
1723:Core/Src/main.c ****         const uint8_t *data = src + (i * BLOCK_DATA_SIZE);
1724:Core/Src/main.c ****         
1725:Core/Src/main.c ****         // Calculate length for THIS specific block
1726:Core/Src/main.c ****         uint16_t currentBlockLen = (remaining > BLOCK_DATA_SIZE) ? BLOCK_DATA_SIZE : remaining;
1727:Core/Src/main.c ****         
1728:Core/Src/main.c ****         // Calculate CRC only for the actual data present in this block
1729:Core/Src/main.c ****         uint16_t crc = crc16(data, currentBlockLen);
1730:Core/Src/main.c **** 
1731:Core/Src/main.c ****         // --- NEW HEADER STRUCTURE ---
1732:Core/Src/main.c ****         // Byte 0-1: Block Length (High byte, then Low byte)
1733:Core/Src/main.c ****         block[0] = (currentBlockLen >> 8) & 0xFF; 
1734:Core/Src/main.c ****         block[1] =  currentBlockLen       & 0xFF; 
1735:Core/Src/main.c ****         
1736:Core/Src/main.c ****         // Byte 2-3: CRC of the data
ARM GAS  /tmp/ccoVOuan.s 			page 86


1737:Core/Src/main.c ****         block[2] = (crc >> 8) & 0xFF;
1738:Core/Src/main.c ****         block[3] =  crc       & 0xFF;
1739:Core/Src/main.c **** 
1740:Core/Src/main.c ****         // Write data
1741:Core/Src/main.c ****         if (currentBlockLen > 0) {
1742:Core/Src/main.c ****             memcpy(&block[4], data, currentBlockLen);
1743:Core/Src/main.c ****         }
1744:Core/Src/main.c **** 
1745:Core/Src/main.c ****         // Optional: Zero out the rest of the 512-byte block if currentBlockLen < BLOCK_DATA_SIZE
1746:Core/Src/main.c ****         if (currentBlockLen < BLOCK_DATA_SIZE) {
1747:Core/Src/main.c ****             memset(&block[4 + currentBlockLen], 0, BLOCK_DATA_SIZE - currentBlockLen);
1748:Core/Src/main.c ****         }
1749:Core/Src/main.c **** 
1750:Core/Src/main.c ****         // Update remaining count
1751:Core/Src/main.c ****         if (remaining >= currentBlockLen) {
1752:Core/Src/main.c ****             remaining -= currentBlockLen;
1753:Core/Src/main.c ****         } else {
1754:Core/Src/main.c ****             remaining = 0;
1755:Core/Src/main.c ****         }
1756:Core/Src/main.c **** 
1757:Core/Src/main.c **** 
1758:Core/Src/main.c ****       
1759:Core/Src/main.c ****     }
