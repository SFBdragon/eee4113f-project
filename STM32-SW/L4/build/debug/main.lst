1650:Core/Src/main.c **** void PackBlocks(const uint8_t *src, uint16_t dataLen) {
1651:Core/Src/main.c ****     // Determine how many bytes go into each block based on total dataLen
1652:Core/Src/main.c ****     uint16_t remaining = dataLen;
1653:Core/Src/main.c **** 
1654:Core/Src/main.c ****     for (uint16_t i = 0; i < NUM_BLOCKS; i++) {
1655:Core/Src/main.c ****         uint8_t *block = packedBlocks[i];
1656:Core/Src/main.c ****         const uint8_t *data = src + (i * BLOCK_DATA_SIZE);
1657:Core/Src/main.c ****         
1658:Core/Src/main.c ****         // Calculate length for THIS specific block
1659:Core/Src/main.c ****         uint16_t currentBlockLen = (remaining > BLOCK_DATA_SIZE) ? BLOCK_DATA_SIZE : remaining;
1660:Core/Src/main.c ****         
1661:Core/Src/main.c ****         // Calculate CRC only for the actual data present in this block
1662:Core/Src/main.c ****         uint16_t crc = crc16(data, currentBlockLen);
1663:Core/Src/main.c **** 
1664:Core/Src/main.c ****         // --- NEW HEADER STRUCTURE ---
1665:Core/Src/main.c ****         // Byte 0-1: Block Length (High byte, then Low byte)
1666:Core/Src/main.c ****         block[0] = (currentBlockLen >> 8) & 0xFF; 
1667:Core/Src/main.c ****         block[1] =  currentBlockLen       & 0xFF; 
1668:Core/Src/main.c ****         
1669:Core/Src/main.c ****         // Byte 2-3: CRC of the data
1670:Core/Src/main.c ****         block[2] = (crc >> 8) & 0xFF;
1671:Core/Src/main.c ****         block[3] =  crc            & 0xFF;
1672:Core/Src/main.c **** 
1673:Core/Src/main.c ****         // Write data
ARM GAS  /tmp/cc8HzfMu.s 			page 84


1674:Core/Src/main.c ****         if (currentBlockLen > 0) {
1675:Core/Src/main.c ****             memcpy(&block[4], data, currentBlockLen);
1676:Core/Src/main.c ****         }
1677:Core/Src/main.c **** 
1678:Core/Src/main.c ****         // Optional: Zero out the rest of the 512-byte block if currentBlockLen < BLOCK_DATA_SIZE
1679:Core/Src/main.c ****         if (currentBlockLen < BLOCK_DATA_SIZE) {
1680:Core/Src/main.c ****             memset(&block[4 + currentBlockLen], 0, BLOCK_DATA_SIZE - currentBlockLen);
1681:Core/Src/main.c ****         }
1682:Core/Src/main.c **** 
1683:Core/Src/main.c ****         // Update remaining count
1684:Core/Src/main.c ****         if (remaining >= currentBlockLen) {
1685:Core/Src/main.c ****             remaining -= currentBlockLen;
1686:Core/Src/main.c ****         } else {
1687:Core/Src/main.c ****             remaining = 0;
1688:Core/Src/main.c ****         }
1689:Core/Src/main.c **** 
1690:Core/Src/main.c **** 
1691:Core/Src/main.c ****       
1692:Core/Src/main.c ****     }
1693:Core/Src/main.c **** }
