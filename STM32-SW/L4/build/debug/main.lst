1200:Core/Src/main.c **** // Direct SDMMC write/read-back test — no FatFS involved
1201:Core/Src/main.c **** void SD_RawWriteTest(void) {
1202:Core/Src/main.c ****     char uart[64];
1203:Core/Src/main.c **** 
1204:Core/Src/main.c ****     // Fill write buffer with known pattern
1205:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
1206:Core/Src/main.c ****         writeBuf[i] = (uint8_t)(i & 0xFF);
1207:Core/Src/main.c ****     }
1208:Core/Src/main.c ****     memset(readBuf, 0xAA, sizeof(readBuf)); // fill read buf with garbage first
1209:Core/Src/main.c **** 
1210:Core/Src/main.c ****     UART_SendString(&huart3, "\r\n--- RAW HAL SD TEST ---\r\n");
1211:Core/Src/main.c **** 
1212:Core/Src/main.c ****     // --- WRITE ---
1213:Core/Src/main.c ****     HAL_StatusTypeDef wStat = HAL_SD_WriteBlocks(&hsd1, writeBuf, 100, 1, 5000);
1214:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "WriteBlocks: %s (%d)\r\n",
1215:Core/Src/main.c ****              wStat == HAL_OK ? "HAL_OK" : "FAILED", wStat);
1216:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1217:Core/Src/main.c **** 
ARM GAS  /tmp/cc1Ioj8q.s 			page 32


1218:Core/Src/main.c ****     if (wStat != HAL_OK) {
1219:Core/Src/main.c ****         // Dump SD error state for more detail
1220:Core/Src/main.c ****         HAL_SD_CardStateTypeDef state = HAL_SD_GetCardState(&hsd1);
1221:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "Card state after write: %d\r\n", (int)state);
1222:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1223:Core/Src/main.c **** 
1224:Core/Src/main.c ****         uint32_t sdErr = hsd1.ErrorCode;    // FAILS WITH SDMMC_ERROR_CMD_CRC_FAIL implying signal 
1225:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "SD ErrorCode: 0x%08lX\r\n", (unsigned long)sdErr);
1226:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1227:Core/Src/main.c ****         return;
1228:Core/Src/main.c ****     }
1229:Core/Src/main.c **** 
1230:Core/Src/main.c **** 
1231:Core/Src/main.c ****     // --- WAIT for card to finish ---
1232:Core/Src/main.c ****     uint32_t t = HAL_GetTick();
1233:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1234:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1235:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after write!\r\n");
1236:Core/Src/main.c ****             return;
1237:Core/Src/main.c ****         }
1238:Core/Src/main.c ****     }
1239:Core/Src/main.c ****     UART_SendString(&huart3, "Card ready after write.\r\n");
1240:Core/Src/main.c **** 
1241:Core/Src/main.c ****     // --- READ BACK ---
1242:Core/Src/main.c ****     HAL_StatusTypeDef rStat = HAL_SD_ReadBlocks(&hsd1, readBuf, 100, 1, 2000);
1243:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "ReadBlocks:  %s (%d)\r\n",
1244:Core/Src/main.c ****              rStat == HAL_OK ? "HAL_OK" : "FAILED", rStat);
1245:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1246:Core/Src/main.c **** 
1247:Core/Src/main.c ****     if (rStat != HAL_OK) return;
1248:Core/Src/main.c **** 
1249:Core/Src/main.c ****     // Wait for card again
1250:Core/Src/main.c ****     t = HAL_GetTick();
1251:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1252:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1253:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after read!\r\n");
1254:Core/Src/main.c ****             return;
1255:Core/Src/main.c ****         }
1256:Core/Src/main.c ****     }
1257:Core/Src/main.c **** 
1258:Core/Src/main.c ****     // --- VERIFY ---
1259:Core/Src/main.c ****     int mismatches = 0;
1260:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
1261:Core/Src/main.c ****         if (readBuf[i] != writeBuf[i]) mismatches++;
1262:Core/Src/main.c ****     }
1263:Core/Src/main.c **** 
1264:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "Verify: %s (%d mismatches)\r\n",
1265:Core/Src/main.c ****              mismatches == 0 ? "PASS" : "FAIL", mismatches);
1266:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1267:Core/Src/main.c ****     UART_SendString(&huart3, "--- END RAW TEST ---\r\n\r\n");
1268:Core/Src/main.c **** }
