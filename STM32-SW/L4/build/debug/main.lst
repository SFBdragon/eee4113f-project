 204:Core/Src/main.c **** // --- Diagnostic block - add temporarily after successful mount ---
 205:Core/Src/main.c **** if (f_mount(&SDFatFS, SDPath, 1) == FR_OK) {
 206:Core/Src/main.c ****     UART_SendString(&huart3, "SD Card Mounted Successfully!\r\n");
 207:Core/Src/main.c **** 
 208:Core/Src/main.c ****     // 1. Check free space (fails if FAT type mismatch or read-only)
 209:Core/Src/main.c ****     DWORD freeClusters;
 210:Core/Src/main.c ****     FATFS *pFatFs;
 211:Core/Src/main.c ****     char diagBuf[64];
 212:Core/Src/main.c **** 
 213:Core/Src/main.c ****     if (f_getfree(SDPath, &freeClusters, &pFatFs) == FR_OK) {
 214:Core/Src/main.c ****         uint32_t freeKB = freeClusters * pFatFs->csize * (pFatFs->csize / 1024);
 215:Core/Src/main.c ****         snprintf(diagBuf, sizeof(diagBuf), "Free space: %lu KB\r\n", (unsigned long)freeKB);
 216:Core/Src/main.c ****         UART_SendString(&huart3, diagBuf);
 217:Core/Src/main.c ****     } else {
 218:Core/Src/main.c ****         UART_SendString(&huart3, "f_getfree FAILED - possible FAT type or config issue\r\n");
 219:Core/Src/main.c ****     }
 220:Core/Src/main.c **** 
 221:Core/Src/main.c ****     // 2. Try creating a brand new test file
 222:Core/Src/main.c ****     FRESULT res = f_open(&SDFile, "TEST.txt", FA_CREATE_ALWAYS | FA_WRITE);
 223:Core/Src/main.c ****     snprintf(diagBuf, sizeof(diagBuf), "f_open TEST.txt result: %d\r\n", res);
 224:Core/Src/main.c ****     UART_SendString(&huart3, diagBuf);
 225:Core/Src/main.c **** 
 226:Core/Src/main.c ****     if (res == FR_OK) {
 227:Core/Src/main.c ****         UINT bw;
 228:Core/Src/main.c ****         FRESULT wres = f_write(&SDFile, "hello", 5, &bw);
 229:Core/Src/main.c ****         snprintf(diagBuf, sizeof(diagBuf), "f_write result: %d, bytes: %u\r\n", wres, bw);
 230:Core/Src/main.c ****         UART_SendString(&huart3, diagBuf);
 231:Core/Src/main.c ****         f_close(&SDFile);
 232:Core/Src/main.c ****     }
 233:Core/Src/main.c **** }
