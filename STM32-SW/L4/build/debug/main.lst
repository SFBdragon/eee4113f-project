 132:Core/Src/main.c ****   ssd1306_Fill(Black);
 133:Core/Src/main.c **** 
 134:Core/Src/main.c ****   // Testing LSE RTC
 135:Core/Src/main.c ****   RTC_TimeTypeDef sTime = {0};
 136:Core/Src/main.c ****   RTC_DateTypeDef sDate = {0};
 137:Core/Src/main.c ****   uint32_t count = 0; // Incrementing timer
 138:Core/Src/main.c ****   char oled_buffer[20]; // Buffer to hold the formatted string
 139:Core/Src/main.c ****   /* USER CODE END 2 */
 140:Core/Src/main.c **** 
 141:Core/Src/main.c ****   /* Infinite loop */
 142:Core/Src/main.c ****   /* USER CODE BEGIN WHILE */
 143:Core/Src/main.c ****   while (1)
 144:Core/Src/main.c ****   { 
 145:Core/Src/main.c ****     // Polling WIFI power for now as indicator
ARM GAS  /tmp/ccS70BWP.s 			page 4


 146:Core/Src/main.c ****     HAL_GPIO_TogglePin(Lo_PWR_CTRL_GPIO_Port, Lo_PWR_CTRL_Pin);
 147:Core/Src/main.c **** 
 148:Core/Src/main.c ****     // Get the current RTC Time to check LSI then LSE
 149:Core/Src/main.c ****     HAL_RTC_GetTime(&hrtc, &sTime, RTC_FORMAT_BIN);
 150:Core/Src/main.c ****     HAL_RTC_GetDate(&hrtc, &sDate, RTC_FORMAT_BIN);
 151:Core/Src/main.c **** 
 152:Core/Src/main.c ****     /* 2. Display Date (Top Line) */
 153:Core/Src/main.c ****     // Format: DD-MM-20YY
 154:Core/Src/main.c ****     sprintf(oled_buffer, "Date: %02d-%02d-20%02d", sDate.Date, sDate.Month, sDate.Year);
 155:Core/Src/main.c ****     ssd1306_SetCursor(0, 0);
 156:Core/Src/main.c ****     ssd1306_WriteString(oled_buffer, Font_7x10, White);
 157:Core/Src/main.c **** 
 158:Core/Src/main.c ****     /* 3. Display Time (Middle Line) */
 159:Core/Src/main.c ****     sprintf(oled_buffer, "%02d:%02d:%02d", sTime.Hours, sTime.Minutes, sTime.Seconds);
 160:Core/Src/main.c ****     ssd1306_SetCursor(0, 15);
 161:Core/Src/main.c ****     ssd1306_WriteString(oled_buffer, Font_11x18, White);
 162:Core/Src/main.c **** 
 163:Core/Src/main.c ****     /* 4. Display Counter (Bottom Line) */
 164:Core/Src/main.c ****     sprintf(oled_buffer, "Count: %lu", count++);
 165:Core/Src/main.c ****     ssd1306_SetCursor(0, 40);
 166:Core/Src/main.c ****    /// ssd1306_WriteString(oled_buffer, Font_7x10, White);
 167:Core/Src/main.c ****     //ssd1306_WriteString("LSE: FAIL", Font_7x10, White);
 168:Core/Src/main.c **** 
 169:Core/Src/main.c ****     /* 5. Refresh Screen */
 170:Core/Src/main.c ****     ssd1306_UpdateScreen();
 171:Core/Src/main.c **** 
 172:Core/Src/main.c ****     if (__HAL_RCC_GET_FLAG(RCC_FLAG_LSERDY)) {
 173:Core/Src/main.c ****     ssd1306_SetCursor(0, 40);
 174:Core/Src/main.c ****     ssd1306_WriteString("LSE: READY", Font_7x10, White);
 175:Core/Src/main.c ****     } else {
 176:Core/Src/main.c ****         ssd1306_SetCursor(0, 40);
 177:Core/Src/main.c ****         ssd1306_WriteString("LSE: FAIL", Font_7x10, White);
 178:Core/Src/main.c ****     }
 179:Core/Src/main.c ****     ssd1306_UpdateScreen();
 180:Core/Src/main.c **** 
 181:Core/Src/main.c ****     HAL_Delay(2000);
 182:Core/Src/main.c ****     
 183:Core/Src/main.c ****     /* USER CODE END WHILE */
 184:Core/Src/main.c **** 
 185:Core/Src/main.c ****     /* USER CODE BEGIN 3 */
 186:Core/Src/main.c ****   }
 187:Core/Src/main.c ****   /* USER CODE END 3 */
 188:Core/Src/main.c **** }
