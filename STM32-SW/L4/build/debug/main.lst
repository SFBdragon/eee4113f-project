 864:Core/Src/main.c **** // Direct SDMMC write/read-back test — no FatFS involved
 865:Core/Src/main.c **** void SD_RawWriteTest(void) {
 866:Core/Src/main.c ****     char uart[64];
 867:Core/Src/main.c **** 
 868:Core/Src/main.c ****     // Fill write buffer with known pattern
 869:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
 870:Core/Src/main.c ****         writeBuf[i] = (uint8_t)(i & 0xFF);
 871:Core/Src/main.c ****     }
 872:Core/Src/main.c ****     memset(readBuf, 0xAA, sizeof(readBuf)); // fill read buf with garbage first
 873:Core/Src/main.c **** 
 874:Core/Src/main.c ****     UART_SendString(&huart3, "\r\n--- RAW HAL SD TEST ---\r\n");
 875:Core/Src/main.c **** 
 876:Core/Src/main.c ****     // --- WRITE ---
 877:Core/Src/main.c ****     HAL_StatusTypeDef wStat = HAL_SD_WriteBlocks(&hsd1, writeBuf, 100, 1, 5000);
 878:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "WriteBlocks: %s (%d)\r\n",
 879:Core/Src/main.c ****              wStat == HAL_OK ? "HAL_OK" : "FAILED", wStat);
 880:Core/Src/main.c ****     UART_SendString(&huart3, uart);
 881:Core/Src/main.c **** 
 882:Core/Src/main.c ****     if (wStat != HAL_OK) {
 883:Core/Src/main.c ****         // Dump SD error state for more detail
 884:Core/Src/main.c ****         HAL_SD_CardStateTypeDef state = HAL_SD_GetCardState(&hsd1);
ARM GAS  /tmp/ccGjMjR9.s 			page 26


 885:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "Card state after write: %d\r\n", (int)state);
 886:Core/Src/main.c ****         UART_SendString(&huart3, uart);
 887:Core/Src/main.c **** 
 888:Core/Src/main.c ****         uint32_t sdErr = hsd1.ErrorCode;    // FAILS WITH SDMMC_ERROR_CMD_CRC_FAIL implying signal 
 889:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "SD ErrorCode: 0x%08lX\r\n", (unsigned long)sdErr);
 890:Core/Src/main.c ****         UART_SendString(&huart3, uart);
 891:Core/Src/main.c ****         return;
 892:Core/Src/main.c ****     }
 893:Core/Src/main.c **** 
 894:Core/Src/main.c **** 
 895:Core/Src/main.c ****     // --- WAIT for card to finish ---
 896:Core/Src/main.c ****     uint32_t t = HAL_GetTick();
 897:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
 898:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
 899:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after write!\r\n");
 900:Core/Src/main.c ****             return;
 901:Core/Src/main.c ****         }
 902:Core/Src/main.c ****     }
 903:Core/Src/main.c ****     UART_SendString(&huart3, "Card ready after write.\r\n");
 904:Core/Src/main.c **** 
 905:Core/Src/main.c ****     // --- READ BACK ---
 906:Core/Src/main.c ****     HAL_StatusTypeDef rStat = HAL_SD_ReadBlocks(&hsd1, readBuf, 100, 1, 2000);
 907:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "ReadBlocks:  %s (%d)\r\n",
 908:Core/Src/main.c ****              rStat == HAL_OK ? "HAL_OK" : "FAILED", rStat);
 909:Core/Src/main.c ****     UART_SendString(&huart3, uart);
 910:Core/Src/main.c **** 
 911:Core/Src/main.c ****     if (rStat != HAL_OK) return;
 912:Core/Src/main.c **** 
 913:Core/Src/main.c ****     // Wait for card again
 914:Core/Src/main.c ****     t = HAL_GetTick();
 915:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
 916:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
 917:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after read!\r\n");
 918:Core/Src/main.c ****             return;
 919:Core/Src/main.c ****         }
 920:Core/Src/main.c ****     }
 921:Core/Src/main.c **** 
 922:Core/Src/main.c ****     // --- VERIFY ---
 923:Core/Src/main.c ****     int mismatches = 0;
 924:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
 925:Core/Src/main.c ****         if (readBuf[i] != writeBuf[i]) mismatches++;
 926:Core/Src/main.c ****     }
 927:Core/Src/main.c **** 
 928:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "Verify: %s (%d mismatches)\r\n",
 929:Core/Src/main.c ****              mismatches == 0 ? "PASS" : "FAIL", mismatches);
 930:Core/Src/main.c ****     UART_SendString(&huart3, uart);
 931:Core/Src/main.c ****     UART_SendString(&huart3, "--- END RAW TEST ---\r\n\r\n");
 932:Core/Src/main.c **** }
