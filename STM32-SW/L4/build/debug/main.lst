1477:Core/Src/main.c **** // Direct SDMMC write/read-back test — no FatFS involved
1478:Core/Src/main.c **** void SD_RawWriteTest(void) {
1479:Core/Src/main.c ****     char uart[64];
1480:Core/Src/main.c **** 
1481:Core/Src/main.c ****     // Fill write buffer with known pattern
1482:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
1483:Core/Src/main.c ****         writeBuf[i] = (uint8_t)(i & 0xFF);
1484:Core/Src/main.c ****     }
1485:Core/Src/main.c ****     memset(readBuf, 0xAA, sizeof(readBuf)); // fill read buf with garbage first
1486:Core/Src/main.c **** 
1487:Core/Src/main.c ****     UART_SendString(&huart3, "\r\n--- RAW HAL SD TEST ---\r\n");
1488:Core/Src/main.c **** 
1489:Core/Src/main.c ****     // --- WRITE ---
1490:Core/Src/main.c ****     HAL_StatusTypeDef wStat = HAL_SD_WriteBlocks(&hsd1, writeBuf, 100, 1, 5000);
1491:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "WriteBlocks: %s (%d)\r\n",
1492:Core/Src/main.c ****              wStat == HAL_OK ? "HAL_OK" : "FAILED", wStat);
1493:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1494:Core/Src/main.c **** 
1495:Core/Src/main.c ****     if (wStat != HAL_OK) {
1496:Core/Src/main.c ****         // Dump SD error state for more detail
1497:Core/Src/main.c ****         HAL_SD_CardStateTypeDef state = HAL_SD_GetCardState(&hsd1);
1498:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "Card state after write: %d\r\n", (int)state);
1499:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1500:Core/Src/main.c **** 
1501:Core/Src/main.c ****         uint32_t sdErr = hsd1.ErrorCode;    // FAILS WITH SDMMC_ERROR_CMD_CRC_FAIL implying signal 
1502:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "SD ErrorCode: 0x%08lX\r\n", (unsigned long)sdErr);
1503:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1504:Core/Src/main.c ****         return;
1505:Core/Src/main.c ****     }
1506:Core/Src/main.c **** 
1507:Core/Src/main.c **** 
1508:Core/Src/main.c ****     // --- WAIT for card to finish ---
1509:Core/Src/main.c ****     uint32_t t = HAL_GetTick();
1510:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1511:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1512:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after write!\r\n");
1513:Core/Src/main.c ****             return;
1514:Core/Src/main.c ****         }
ARM GAS  /tmp/ccoVOuan.s 			page 37


1515:Core/Src/main.c ****     }
1516:Core/Src/main.c ****     UART_SendString(&huart3, "Card ready after write.\r\n");
1517:Core/Src/main.c **** 
1518:Core/Src/main.c ****     // --- READ BACK ---
1519:Core/Src/main.c ****     HAL_StatusTypeDef rStat = HAL_SD_ReadBlocks(&hsd1, readBuf, 100, 1, 2000);
1520:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "ReadBlocks:  %s (%d)\r\n",
1521:Core/Src/main.c ****              rStat == HAL_OK ? "HAL_OK" : "FAILED", rStat);
1522:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1523:Core/Src/main.c **** 
1524:Core/Src/main.c ****     if (rStat != HAL_OK) return;
1525:Core/Src/main.c **** 
1526:Core/Src/main.c ****     // Wait for card again
1527:Core/Src/main.c ****     t = HAL_GetTick();
1528:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1529:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1530:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after read!\r\n");
1531:Core/Src/main.c ****             return;
1532:Core/Src/main.c ****         }
1533:Core/Src/main.c ****     }
1534:Core/Src/main.c **** 
1535:Core/Src/main.c ****     // --- VERIFY ---
1536:Core/Src/main.c ****     int mismatches = 0;
1537:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
1538:Core/Src/main.c ****         if (readBuf[i] != writeBuf[i]) mismatches++;
1539:Core/Src/main.c ****     }
1540:Core/Src/main.c **** 
1541:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "Verify: %s (%d mismatches)\r\n",
1542:Core/Src/main.c ****              mismatches == 0 ? "PASS" : "FAIL", mismatches);
1543:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1544:Core/Src/main.c ****     UART_SendString(&huart3, "--- END RAW TEST ---\r\n\r\n");
1545:Core/Src/main.c **** }
