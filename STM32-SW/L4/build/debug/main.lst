 819:Core/Src/main.c **** // Direct SDMMC write/read-back test — no FatFS involved
 820:Core/Src/main.c **** void SD_RawWriteTest(void) {
 821:Core/Src/main.c ****     char uart[64];
 822:Core/Src/main.c **** 
 823:Core/Src/main.c ****     // Fill write buffer with known pattern
 824:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
 825:Core/Src/main.c ****         writeBuf[i] = (uint8_t)(i & 0xFF);
 826:Core/Src/main.c ****     }
 827:Core/Src/main.c ****     memset(readBuf, 0xAA, sizeof(readBuf)); // fill read buf with garbage first
 828:Core/Src/main.c **** 
 829:Core/Src/main.c ****     UART_SendString(&huart3, "\r\n--- RAW HAL SD TEST ---\r\n");
 830:Core/Src/main.c **** 
 831:Core/Src/main.c ****     // --- WRITE ---
 832:Core/Src/main.c ****     HAL_StatusTypeDef wStat = HAL_SD_WriteBlocks(&hsd1, writeBuf, 100, 1, 5000);
 833:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "WriteBlocks: %s (%d)\r\n",
 834:Core/Src/main.c ****              wStat == HAL_OK ? "HAL_OK" : "FAILED", wStat);
 835:Core/Src/main.c ****     UART_SendString(&huart3, uart);
 836:Core/Src/main.c **** 
 837:Core/Src/main.c ****     if (wStat != HAL_OK) {
 838:Core/Src/main.c ****         // Dump SD error state for more detail
 839:Core/Src/main.c ****         HAL_SD_CardStateTypeDef state = HAL_SD_GetCardState(&hsd1);
ARM GAS  /tmp/ccpgJVM9.s 			page 26


 840:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "Card state after write: %d\r\n", (int)state);
 841:Core/Src/main.c ****         UART_SendString(&huart3, uart);
 842:Core/Src/main.c **** 
 843:Core/Src/main.c ****         uint32_t sdErr = hsd1.ErrorCode;    // FAILS WITH SDMMC_ERROR_CMD_CRC_FAIL implying signal 
 844:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "SD ErrorCode: 0x%08lX\r\n", (unsigned long)sdErr);
 845:Core/Src/main.c ****         UART_SendString(&huart3, uart);
 846:Core/Src/main.c ****         return;
 847:Core/Src/main.c ****     }
 848:Core/Src/main.c **** 
 849:Core/Src/main.c **** 
 850:Core/Src/main.c ****     // --- WAIT for card to finish ---
 851:Core/Src/main.c ****     uint32_t t = HAL_GetTick();
 852:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
 853:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
 854:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after write!\r\n");
 855:Core/Src/main.c ****             return;
 856:Core/Src/main.c ****         }
 857:Core/Src/main.c ****     }
 858:Core/Src/main.c ****     UART_SendString(&huart3, "Card ready after write.\r\n");
 859:Core/Src/main.c **** 
 860:Core/Src/main.c ****     // --- READ BACK ---
 861:Core/Src/main.c ****     HAL_StatusTypeDef rStat = HAL_SD_ReadBlocks(&hsd1, readBuf, 100, 1, 2000);
 862:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "ReadBlocks:  %s (%d)\r\n",
 863:Core/Src/main.c ****              rStat == HAL_OK ? "HAL_OK" : "FAILED", rStat);
 864:Core/Src/main.c ****     UART_SendString(&huart3, uart);
 865:Core/Src/main.c **** 
 866:Core/Src/main.c ****     if (rStat != HAL_OK) return;
 867:Core/Src/main.c **** 
 868:Core/Src/main.c ****     // Wait for card again
 869:Core/Src/main.c ****     t = HAL_GetTick();
 870:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
 871:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
 872:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after read!\r\n");
 873:Core/Src/main.c ****             return;
 874:Core/Src/main.c ****         }
 875:Core/Src/main.c ****     }
 876:Core/Src/main.c **** 
 877:Core/Src/main.c ****     // --- VERIFY ---
 878:Core/Src/main.c ****     int mismatches = 0;
 879:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
 880:Core/Src/main.c ****         if (readBuf[i] != writeBuf[i]) mismatches++;
 881:Core/Src/main.c ****     }
 882:Core/Src/main.c **** 
 883:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "Verify: %s (%d mismatches)\r\n",
 884:Core/Src/main.c ****              mismatches == 0 ? "PASS" : "FAIL", mismatches);
 885:Core/Src/main.c ****     UART_SendString(&huart3, uart);
 886:Core/Src/main.c ****     UART_SendString(&huart3, "--- END RAW TEST ---\r\n\r\n");
 887:Core/Src/main.c **** }
