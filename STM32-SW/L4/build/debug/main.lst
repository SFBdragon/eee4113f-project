1611:Core/Src/main.c **** 
1612:Core/Src/main.c **** void flush_block_buffer_to_disk(void) {
1613:Core/Src/main.c ****     // How many bytes are in the current half that haven't been written yet
1614:Core/Src/main.c ****     uint16_t remaining = rx_write_pos % (RX_BUF_SIZE / 2);
1615:Core/Src/main.c **** 
1616:Core/Src/main.c ****     if (remaining == 0) {
1617:Core/Src/main.c ****         UART_SendString(&huart3, "Flush: nothing to flush\r\n");
1618:Core/Src/main.c ****         return;
1619:Core/Src/main.c ****     }
1620:Core/Src/main.c **** 
1621:Core/Src/main.c ****     char dbg[64];
1622:Core/Src/main.c ****     snprintf(dbg, sizeof(dbg), "Flushing %d remaining bytes\r\n", remaining);
1623:Core/Src/main.c ****     UART_SendString(&huart3, dbg);
1624:Core/Src/main.c **** 
1625:Core/Src/main.c ****     // Determine which half we're currently in
1626:Core/Src/main.c ****     uint8_t *src = (rx_write_pos < (RX_BUF_SIZE / 2))
1627:Core/Src/main.c ****                     ? rxBuffer                        // first half
1628:Core/Src/main.c ****                     : rxBuffer + (RX_BUF_SIZE / 2);  // second half
1629:Core/Src/main.c **** 
1630:Core/Src/main.c ****     // Pack and write only the remaining bytes
1631:Core/Src/main.c ****     PackBlocks(src, remaining);
1632:Core/Src/main.c **** 
1633:Core/Src/main.c ****     HAL_SD_DeInit(&hsd1);
1634:Core/Src/main.c ****     MX_SDMMC1_SD_Init();
1635:Core/Src/main.c **** 
1636:Core/Src/main.c ****     for (uint16_t i = 0; i < NUM_BLOCKS; i++) {
1637:Core/Src/main.c ****         SD_Stream_WriteBlock(packedBlocks[i]);
1638:Core/Src/main.c ****     }
1639:Core/Src/main.c **** 
1640:Core/Src/main.c ****     rx_write_pos = 0;  // reset after flush
1641:Core/Src/main.c ****     UART_SendString(&huart3, "Flush complete\r\n");
1642:Core/Src/main.c **** }
