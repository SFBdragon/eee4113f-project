1401:Core/Src/main.c **** 
1402:Core/Src/main.c **** // Direct SDMMC write/read-back test — no FatFS involved
1403:Core/Src/main.c **** void SD_RawWriteTest(void) {
1404:Core/Src/main.c ****     char uart[64];
1405:Core/Src/main.c **** 
1406:Core/Src/main.c ****     // Fill write buffer with known pattern
1407:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
1408:Core/Src/main.c ****         writeBuf[i] = (uint8_t)(i & 0xFF);
1409:Core/Src/main.c ****     }
1410:Core/Src/main.c ****     memset(readBuf, 0xAA, sizeof(readBuf)); // fill read buf with garbage first
1411:Core/Src/main.c **** 
1412:Core/Src/main.c ****     UART_SendString(&huart3, "\r\n--- RAW HAL SD TEST ---\r\n");
1413:Core/Src/main.c **** 
1414:Core/Src/main.c ****     // --- WRITE ---
1415:Core/Src/main.c ****     HAL_StatusTypeDef wStat = HAL_SD_WriteBlocks(&hsd1, writeBuf, 100, 1, 5000);
1416:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "WriteBlocks: %s (%d)\r\n",
1417:Core/Src/main.c ****              wStat == HAL_OK ? "HAL_OK" : "FAILED", wStat);
1418:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1419:Core/Src/main.c **** 
1420:Core/Src/main.c ****     if (wStat != HAL_OK) {
1421:Core/Src/main.c ****         // Dump SD error state for more detail
1422:Core/Src/main.c ****         HAL_SD_CardStateTypeDef state = HAL_SD_GetCardState(&hsd1);
1423:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "Card state after write: %d\r\n", (int)state);
1424:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1425:Core/Src/main.c **** 
1426:Core/Src/main.c ****         uint32_t sdErr = hsd1.ErrorCode;    // FAILS WITH SDMMC_ERROR_CMD_CRC_FAIL implying signal 
1427:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "SD ErrorCode: 0x%08lX\r\n", (unsigned long)sdErr);
1428:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1429:Core/Src/main.c ****         return;
1430:Core/Src/main.c ****     }
1431:Core/Src/main.c **** 
1432:Core/Src/main.c **** 
1433:Core/Src/main.c ****     // --- WAIT for card to finish ---
1434:Core/Src/main.c ****     uint32_t t = HAL_GetTick();
1435:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1436:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1437:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after write!\r\n");
1438:Core/Src/main.c ****             return;
1439:Core/Src/main.c ****         }
1440:Core/Src/main.c ****     }
1441:Core/Src/main.c ****     UART_SendString(&huart3, "Card ready after write.\r\n");
1442:Core/Src/main.c **** 
1443:Core/Src/main.c ****     // --- READ BACK ---
1444:Core/Src/main.c ****     HAL_StatusTypeDef rStat = HAL_SD_ReadBlocks(&hsd1, readBuf, 100, 1, 2000);
1445:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "ReadBlocks:  %s (%d)\r\n",
1446:Core/Src/main.c ****              rStat == HAL_OK ? "HAL_OK" : "FAILED", rStat);
1447:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1448:Core/Src/main.c **** 
1449:Core/Src/main.c ****     if (rStat != HAL_OK) return;
1450:Core/Src/main.c **** 
1451:Core/Src/main.c ****     // Wait for card again
1452:Core/Src/main.c ****     t = HAL_GetTick();
1453:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1454:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1455:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after read!\r\n");
1456:Core/Src/main.c ****             return;
1457:Core/Src/main.c ****         }
ARM GAS  /tmp/cc9xU29h.s 			page 36


1458:Core/Src/main.c ****     }
1459:Core/Src/main.c **** 
1460:Core/Src/main.c ****     // --- VERIFY ---
1461:Core/Src/main.c ****     int mismatches = 0;
1462:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
1463:Core/Src/main.c ****         if (readBuf[i] != writeBuf[i]) mismatches++;
1464:Core/Src/main.c ****     }
1465:Core/Src/main.c **** 
