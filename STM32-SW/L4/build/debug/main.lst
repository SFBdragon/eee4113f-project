 862:Core/Src/main.c **** // Direct SDMMC write/read-back test — no FatFS involved
 863:Core/Src/main.c **** void SD_RawWriteTest(void) {
 864:Core/Src/main.c ****     char uart[64];
 865:Core/Src/main.c **** 
 866:Core/Src/main.c ****     // Fill write buffer with known pattern
 867:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
 868:Core/Src/main.c ****         writeBuf[i] = (uint8_t)(i & 0xFF);
 869:Core/Src/main.c ****     }
 870:Core/Src/main.c ****     memset(readBuf, 0xAA, sizeof(readBuf)); // fill read buf with garbage first
 871:Core/Src/main.c **** 
 872:Core/Src/main.c ****     UART_SendString(&huart3, "\r\n--- RAW HAL SD TEST ---\r\n");
 873:Core/Src/main.c **** 
 874:Core/Src/main.c ****     // --- WRITE ---
 875:Core/Src/main.c ****     HAL_StatusTypeDef wStat = HAL_SD_WriteBlocks(&hsd1, writeBuf, 100, 1, 5000);
 876:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "WriteBlocks: %s (%d)\r\n",
 877:Core/Src/main.c ****              wStat == HAL_OK ? "HAL_OK" : "FAILED", wStat);
 878:Core/Src/main.c ****     UART_SendString(&huart3, uart);
 879:Core/Src/main.c **** 
 880:Core/Src/main.c ****     if (wStat != HAL_OK) {
 881:Core/Src/main.c ****         // Dump SD error state for more detail
 882:Core/Src/main.c ****         HAL_SD_CardStateTypeDef state = HAL_SD_GetCardState(&hsd1);
 883:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "Card state after write: %d\r\n", (int)state);
 884:Core/Src/main.c ****         UART_SendString(&huart3, uart);
 885:Core/Src/main.c **** 
 886:Core/Src/main.c ****         uint32_t sdErr = hsd1.ErrorCode;    // FAILS WITH SDMMC_ERROR_CMD_CRC_FAIL implying signal 
 887:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "SD ErrorCode: 0x%08lX\r\n", (unsigned long)sdErr);
 888:Core/Src/main.c ****         UART_SendString(&huart3, uart);
 889:Core/Src/main.c ****         return;
 890:Core/Src/main.c ****     }
 891:Core/Src/main.c **** 
 892:Core/Src/main.c **** 
ARM GAS  /tmp/ccmWE5gL.s 			page 26


 893:Core/Src/main.c ****     // --- WAIT for card to finish ---
 894:Core/Src/main.c ****     uint32_t t = HAL_GetTick();
 895:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
 896:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
 897:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after write!\r\n");
 898:Core/Src/main.c ****             return;
 899:Core/Src/main.c ****         }
 900:Core/Src/main.c ****     }
 901:Core/Src/main.c ****     UART_SendString(&huart3, "Card ready after write.\r\n");
 902:Core/Src/main.c **** 
 903:Core/Src/main.c ****     // --- READ BACK ---
 904:Core/Src/main.c ****     HAL_StatusTypeDef rStat = HAL_SD_ReadBlocks(&hsd1, readBuf, 100, 1, 2000);
 905:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "ReadBlocks:  %s (%d)\r\n",
 906:Core/Src/main.c ****              rStat == HAL_OK ? "HAL_OK" : "FAILED", rStat);
 907:Core/Src/main.c ****     UART_SendString(&huart3, uart);
 908:Core/Src/main.c **** 
 909:Core/Src/main.c ****     if (rStat != HAL_OK) return;
 910:Core/Src/main.c **** 
 911:Core/Src/main.c ****     // Wait for card again
 912:Core/Src/main.c ****     t = HAL_GetTick();
 913:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
 914:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
 915:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after read!\r\n");
 916:Core/Src/main.c ****             return;
 917:Core/Src/main.c ****         }
 918:Core/Src/main.c ****     }
 919:Core/Src/main.c **** 
 920:Core/Src/main.c ****     // --- VERIFY ---
 921:Core/Src/main.c ****     int mismatches = 0;
 922:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
 923:Core/Src/main.c ****         if (readBuf[i] != writeBuf[i]) mismatches++;
 924:Core/Src/main.c ****     }
 925:Core/Src/main.c **** 
 926:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "Verify: %s (%d mismatches)\r\n",
 927:Core/Src/main.c ****              mismatches == 0 ? "PASS" : "FAIL", mismatches);
 928:Core/Src/main.c ****     UART_SendString(&huart3, uart);
 929:Core/Src/main.c ****     UART_SendString(&huart3, "--- END RAW TEST ---\r\n\r\n");
 930:Core/Src/main.c **** }
