1289:Core/Src/main.c **** 
1290:Core/Src/main.c **** // Direct SDMMC write/read-back test — no FatFS involved
1291:Core/Src/main.c **** void SD_RawWriteTest(void) {
1292:Core/Src/main.c ****     char uart[64];
1293:Core/Src/main.c **** 
1294:Core/Src/main.c ****     // Fill write buffer with known pattern
1295:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
1296:Core/Src/main.c ****         writeBuf[i] = (uint8_t)(i & 0xFF);
1297:Core/Src/main.c ****     }
1298:Core/Src/main.c ****     memset(readBuf, 0xAA, sizeof(readBuf)); // fill read buf with garbage first
1299:Core/Src/main.c **** 
1300:Core/Src/main.c ****     UART_SendString(&huart3, "\r\n--- RAW HAL SD TEST ---\r\n");
1301:Core/Src/main.c **** 
1302:Core/Src/main.c ****     // --- WRITE ---
1303:Core/Src/main.c ****     HAL_StatusTypeDef wStat = HAL_SD_WriteBlocks(&hsd1, writeBuf, 100, 1, 5000);
1304:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "WriteBlocks: %s (%d)\r\n",
1305:Core/Src/main.c ****              wStat == HAL_OK ? "HAL_OK" : "FAILED", wStat);
1306:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1307:Core/Src/main.c **** 
1308:Core/Src/main.c ****     if (wStat != HAL_OK) {
1309:Core/Src/main.c ****         // Dump SD error state for more detail
1310:Core/Src/main.c ****         HAL_SD_CardStateTypeDef state = HAL_SD_GetCardState(&hsd1);
1311:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "Card state after write: %d\r\n", (int)state);
1312:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1313:Core/Src/main.c **** 
1314:Core/Src/main.c ****         uint32_t sdErr = hsd1.ErrorCode;    // FAILS WITH SDMMC_ERROR_CMD_CRC_FAIL implying signal 
1315:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "SD ErrorCode: 0x%08lX\r\n", (unsigned long)sdErr);
1316:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1317:Core/Src/main.c ****         return;
1318:Core/Src/main.c ****     }
1319:Core/Src/main.c **** 
1320:Core/Src/main.c **** 
1321:Core/Src/main.c ****     // --- WAIT for card to finish ---
1322:Core/Src/main.c ****     uint32_t t = HAL_GetTick();
1323:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1324:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1325:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after write!\r\n");
1326:Core/Src/main.c ****             return;
1327:Core/Src/main.c ****         }
1328:Core/Src/main.c ****     }
1329:Core/Src/main.c ****     UART_SendString(&huart3, "Card ready after write.\r\n");
1330:Core/Src/main.c **** 
1331:Core/Src/main.c ****     // --- READ BACK ---
1332:Core/Src/main.c ****     HAL_StatusTypeDef rStat = HAL_SD_ReadBlocks(&hsd1, readBuf, 100, 1, 2000);
1333:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "ReadBlocks:  %s (%d)\r\n",
1334:Core/Src/main.c ****              rStat == HAL_OK ? "HAL_OK" : "FAILED", rStat);
1335:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1336:Core/Src/main.c **** 
1337:Core/Src/main.c ****     if (rStat != HAL_OK) return;
1338:Core/Src/main.c **** 
1339:Core/Src/main.c ****     // Wait for card again
1340:Core/Src/main.c ****     t = HAL_GetTick();
1341:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1342:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1343:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after read!\r\n");
