1419:Core/Src/main.c **** // Direct SDMMC write/read-back test — no FatFS involved
1420:Core/Src/main.c **** void SD_RawWriteTest(void) {
1421:Core/Src/main.c ****     char uart[64];
1422:Core/Src/main.c **** 
1423:Core/Src/main.c ****     // Fill write buffer with known pattern
1424:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
1425:Core/Src/main.c ****         writeBuf[i] = (uint8_t)(i & 0xFF);
1426:Core/Src/main.c ****     }
1427:Core/Src/main.c ****     memset(readBuf, 0xAA, sizeof(readBuf)); // fill read buf with garbage first
1428:Core/Src/main.c **** 
1429:Core/Src/main.c ****     UART_SendString(&huart3, "\r\n--- RAW HAL SD TEST ---\r\n");
1430:Core/Src/main.c **** 
1431:Core/Src/main.c ****     // --- WRITE ---
1432:Core/Src/main.c ****     HAL_StatusTypeDef wStat = HAL_SD_WriteBlocks(&hsd1, writeBuf, 100, 1, 5000);
1433:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "WriteBlocks: %s (%d)\r\n",
1434:Core/Src/main.c ****              wStat == HAL_OK ? "HAL_OK" : "FAILED", wStat);
1435:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1436:Core/Src/main.c **** 
1437:Core/Src/main.c ****     if (wStat != HAL_OK) {
1438:Core/Src/main.c ****         // Dump SD error state for more detail
1439:Core/Src/main.c ****         HAL_SD_CardStateTypeDef state = HAL_SD_GetCardState(&hsd1);
1440:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "Card state after write: %d\r\n", (int)state);
1441:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1442:Core/Src/main.c **** 
1443:Core/Src/main.c ****         uint32_t sdErr = hsd1.ErrorCode;    // FAILS WITH SDMMC_ERROR_CMD_CRC_FAIL implying signal 
1444:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "SD ErrorCode: 0x%08lX\r\n", (unsigned long)sdErr);
1445:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1446:Core/Src/main.c ****         return;
1447:Core/Src/main.c ****     }
1448:Core/Src/main.c **** 
1449:Core/Src/main.c **** 
1450:Core/Src/main.c ****     // --- WAIT for card to finish ---
1451:Core/Src/main.c ****     uint32_t t = HAL_GetTick();
1452:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1453:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1454:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after write!\r\n");
1455:Core/Src/main.c ****             return;
1456:Core/Src/main.c ****         }
1457:Core/Src/main.c ****     }
ARM GAS  /tmp/cc8HzfMu.s 			page 36


1458:Core/Src/main.c ****     UART_SendString(&huart3, "Card ready after write.\r\n");
1459:Core/Src/main.c **** 
1460:Core/Src/main.c ****     // --- READ BACK ---
1461:Core/Src/main.c ****     HAL_StatusTypeDef rStat = HAL_SD_ReadBlocks(&hsd1, readBuf, 100, 1, 2000);
1462:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "ReadBlocks:  %s (%d)\r\n",
1463:Core/Src/main.c ****              rStat == HAL_OK ? "HAL_OK" : "FAILED", rStat);
1464:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1465:Core/Src/main.c **** 
1466:Core/Src/main.c ****     if (rStat != HAL_OK) return;
1467:Core/Src/main.c **** 
1468:Core/Src/main.c ****     // Wait for card again
1469:Core/Src/main.c ****     t = HAL_GetTick();
1470:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1471:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1472:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after read!\r\n");
1473:Core/Src/main.c ****             return;
1474:Core/Src/main.c ****         }
1475:Core/Src/main.c ****     }
1476:Core/Src/main.c **** 
1477:Core/Src/main.c ****     // --- VERIFY ---
1478:Core/Src/main.c ****     int mismatches = 0;
1479:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
1480:Core/Src/main.c ****         if (readBuf[i] != writeBuf[i]) mismatches++;
1481:Core/Src/main.c ****     }
1482:Core/Src/main.c **** 
1483:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "Verify: %s (%d mismatches)\r\n",
1484:Core/Src/main.c ****              mismatches == 0 ? "PASS" : "FAIL", mismatches);
1485:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1486:Core/Src/main.c ****     UART_SendString(&huart3, "--- END RAW TEST ---\r\n\r\n");
1487:Core/Src/main.c **** }
