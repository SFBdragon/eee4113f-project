 324:Core/Src/main.c ****   // Testing with While loop
 325:Core/Src/main.c ****   while(0){
 326:Core/Src/main.c ****     HAL_GPIO_WritePin(Lo_PWR_CTRL_GPIO_Port, Lo_PWR_CTRL_Pin, GPIO_PIN_RESET);
 327:Core/Src/main.c ****     HAL_Delay(1000);
 328:Core/Src/main.c ****     HAL_GPIO_WritePin(Lo_PWR_CTRL_GPIO_Port, Lo_PWR_CTRL_Pin, GPIO_PIN_SET);
 329:Core/Src/main.c ****     HAL_Delay(1000);
