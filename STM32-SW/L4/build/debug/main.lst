1147:Core/Src/main.c **** // Direct SDMMC write/read-back test — no FatFS involved
1148:Core/Src/main.c **** void SD_RawWriteTest(void) {
1149:Core/Src/main.c ****     char uart[64];
1150:Core/Src/main.c **** 
1151:Core/Src/main.c ****     // Fill write buffer with known pattern
1152:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
1153:Core/Src/main.c ****         writeBuf[i] = (uint8_t)(i & 0xFF);
1154:Core/Src/main.c ****     }
1155:Core/Src/main.c ****     memset(readBuf, 0xAA, sizeof(readBuf)); // fill read buf with garbage first
1156:Core/Src/main.c **** 
1157:Core/Src/main.c ****     UART_SendString(&huart3, "\r\n--- RAW HAL SD TEST ---\r\n");
1158:Core/Src/main.c **** 
1159:Core/Src/main.c ****     // --- WRITE ---
1160:Core/Src/main.c ****     HAL_StatusTypeDef wStat = HAL_SD_WriteBlocks(&hsd1, writeBuf, 100, 1, 5000);
ARM GAS  /tmp/ccVn05Lp.s 			page 31


1161:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "WriteBlocks: %s (%d)\r\n",
1162:Core/Src/main.c ****              wStat == HAL_OK ? "HAL_OK" : "FAILED", wStat);
1163:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1164:Core/Src/main.c **** 
1165:Core/Src/main.c ****     if (wStat != HAL_OK) {
1166:Core/Src/main.c ****         // Dump SD error state for more detail
1167:Core/Src/main.c ****         HAL_SD_CardStateTypeDef state = HAL_SD_GetCardState(&hsd1);
1168:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "Card state after write: %d\r\n", (int)state);
1169:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1170:Core/Src/main.c **** 
1171:Core/Src/main.c ****         uint32_t sdErr = hsd1.ErrorCode;    // FAILS WITH SDMMC_ERROR_CMD_CRC_FAIL implying signal 
1172:Core/Src/main.c ****         snprintf(uart, sizeof(uart), "SD ErrorCode: 0x%08lX\r\n", (unsigned long)sdErr);
1173:Core/Src/main.c ****         UART_SendString(&huart3, uart);
1174:Core/Src/main.c ****         return;
1175:Core/Src/main.c ****     }
1176:Core/Src/main.c **** 
1177:Core/Src/main.c **** 
1178:Core/Src/main.c ****     // --- WAIT for card to finish ---
1179:Core/Src/main.c ****     uint32_t t = HAL_GetTick();
1180:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1181:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1182:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after write!\r\n");
1183:Core/Src/main.c ****             return;
1184:Core/Src/main.c ****         }
1185:Core/Src/main.c ****     }
1186:Core/Src/main.c ****     UART_SendString(&huart3, "Card ready after write.\r\n");
1187:Core/Src/main.c **** 
1188:Core/Src/main.c ****     // --- READ BACK ---
1189:Core/Src/main.c ****     HAL_StatusTypeDef rStat = HAL_SD_ReadBlocks(&hsd1, readBuf, 100, 1, 2000);
1190:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "ReadBlocks:  %s (%d)\r\n",
1191:Core/Src/main.c ****              rStat == HAL_OK ? "HAL_OK" : "FAILED", rStat);
1192:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1193:Core/Src/main.c **** 
1194:Core/Src/main.c ****     if (rStat != HAL_OK) return;
1195:Core/Src/main.c **** 
1196:Core/Src/main.c ****     // Wait for card again
1197:Core/Src/main.c ****     t = HAL_GetTick();
1198:Core/Src/main.c ****     while (HAL_SD_GetCardState(&hsd1) != HAL_SD_CARD_TRANSFER) {
1199:Core/Src/main.c ****         if (HAL_GetTick() - t > 2000) {
1200:Core/Src/main.c ****             UART_SendString(&huart3, "Timeout waiting for card after read!\r\n");
1201:Core/Src/main.c ****             return;
1202:Core/Src/main.c ****         }
1203:Core/Src/main.c ****     }
1204:Core/Src/main.c **** 
1205:Core/Src/main.c ****     // --- VERIFY ---
1206:Core/Src/main.c ****     int mismatches = 0;
1207:Core/Src/main.c ****     for (int i = 0; i < 512; i++) {
1208:Core/Src/main.c ****         if (readBuf[i] != writeBuf[i]) mismatches++;
1209:Core/Src/main.c ****     }
1210:Core/Src/main.c **** 
1211:Core/Src/main.c ****     snprintf(uart, sizeof(uart), "Verify: %s (%d mismatches)\r\n",
1212:Core/Src/main.c ****              mismatches == 0 ? "PASS" : "FAIL", mismatches);
1213:Core/Src/main.c ****     UART_SendString(&huart3, uart);
1214:Core/Src/main.c ****     UART_SendString(&huart3, "--- END RAW TEST ---\r\n\r\n");
1215:Core/Src/main.c **** }
