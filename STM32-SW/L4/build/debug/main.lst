1398:Core/Src/main.c ****         uint8_t *block = packedBlocks[i];
1399:Core/Src/main.c ****         const uint8_t *data = src + (i * BLOCK_DATA_SIZE);
1400:Core/Src/main.c ****         
1401:Core/Src/main.c ****         // Calculate length for THIS specific block
1402:Core/Src/main.c ****         uint16_t currentBlockLen = (remaining > BLOCK_DATA_SIZE) ? BLOCK_DATA_SIZE : remaining;
1403:Core/Src/main.c ****         
ARM GAS  /tmp/ccjyVh29.s 			page 92


1404:Core/Src/main.c ****         // Calculate CRC only for the actual data present in this block
1405:Core/Src/main.c ****         uint16_t crc = CRC16(data, currentBlockLen);
1406:Core/Src/main.c **** 
1407:Core/Src/main.c ****         // --- NEW HEADER STRUCTURE ---
1408:Core/Src/main.c ****         // Byte 0-1: Block Length (High byte, then Low byte)
1409:Core/Src/main.c ****         block[0] = (currentBlockLen >> 8) & 0xFF; 
1410:Core/Src/main.c ****         block[1] =  currentBlockLen       & 0xFF; 
1411:Core/Src/main.c ****         
1412:Core/Src/main.c ****         // Byte 2-3: CRC of the data
1413:Core/Src/main.c ****         block[2] = (crc >> 8) & 0xFF;
1414:Core/Src/main.c ****         block[3] =  crc            & 0xFF;
1415:Core/Src/main.c **** 
1416:Core/Src/main.c ****         // Write data
1417:Core/Src/main.c ****         if (currentBlockLen > 0) {
1418:Core/Src/main.c ****             memcpy(&block[4], data, currentBlockLen);
1419:Core/Src/main.c ****         }
1420:Core/Src/main.c **** 
1421:Core/Src/main.c ****         // Optional: Zero out the rest of the 512-byte block if currentBlockLen < BLOCK_DATA_SIZE
1422:Core/Src/main.c ****         if (currentBlockLen < BLOCK_DATA_SIZE) {
1423:Core/Src/main.c ****             memset(&block[4 + currentBlockLen], 0, BLOCK_DATA_SIZE - currentBlockLen);
1424:Core/Src/main.c ****         }
1425:Core/Src/main.c **** 
1426:Core/Src/main.c ****         // Update remaining count
1427:Core/Src/main.c ****         if (remaining >= currentBlockLen) {
1428:Core/Src/main.c ****             remaining -= currentBlockLen;
1429:Core/Src/main.c ****         } else {
1430:Core/Src/main.c ****             remaining = 0;
1431:Core/Src/main.c ****         }
1432:Core/Src/main.c **** 
1433:Core/Src/main.c **** 
1434:Core/Src/main.c ****       
1435:Core/Src/main.c ****     }
1436:Core/Src/main.c **** }
