1420:Core/Src/main.c ****     for (uint16_t i = 0; i < NUM_BLOCKS; i++) {
1421:Core/Src/main.c ****         uint8_t *block = packedBlocks[i];
1422:Core/Src/main.c ****         const uint8_t *data = src + (i * BLOCK_DATA_SIZE);
1423:Core/Src/main.c ****         
1424:Core/Src/main.c ****         // Calculate length for THIS specific block
1425:Core/Src/main.c ****         uint16_t currentBlockLen = (remaining > BLOCK_DATA_SIZE) ? BLOCK_DATA_SIZE : remaining;
1426:Core/Src/main.c ****         
1427:Core/Src/main.c ****         // Calculate CRC only for the actual data present in this block
1428:Core/Src/main.c ****         uint16_t crc = CRC16(data, currentBlockLen);
1429:Core/Src/main.c **** 
1430:Core/Src/main.c ****         // --- NEW HEADER STRUCTURE ---
1431:Core/Src/main.c ****         // Byte 0-1: Block Length (High byte, then Low byte)
1432:Core/Src/main.c ****         block[0] = (currentBlockLen >> 8) & 0xFF; 
1433:Core/Src/main.c ****         block[1] =  currentBlockLen       & 0xFF; 
1434:Core/Src/main.c ****         
1435:Core/Src/main.c ****         // Byte 2-3: CRC of the data
1436:Core/Src/main.c ****         block[2] = (crc >> 8) & 0xFF;
1437:Core/Src/main.c ****         block[3] =  crc            & 0xFF;
1438:Core/Src/main.c **** 
1439:Core/Src/main.c ****         // Write data
1440:Core/Src/main.c ****         if (currentBlockLen > 0) {
1441:Core/Src/main.c ****             memcpy(&block[4], data, currentBlockLen);
1442:Core/Src/main.c ****         }
1443:Core/Src/main.c **** 
1444:Core/Src/main.c ****         // Optional: Zero out the rest of the 512-byte block if currentBlockLen < BLOCK_DATA_SIZE
1445:Core/Src/main.c ****         if (currentBlockLen < BLOCK_DATA_SIZE) {
1446:Core/Src/main.c ****             memset(&block[4 + currentBlockLen], 0, BLOCK_DATA_SIZE - currentBlockLen);
1447:Core/Src/main.c ****         }
1448:Core/Src/main.c **** 
1449:Core/Src/main.c ****         // Update remaining count
1450:Core/Src/main.c ****         if (remaining >= currentBlockLen) {
