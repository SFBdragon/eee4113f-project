 457:Core/Src/main.c ****               UART_SendString(&huart3, hex);
 458:Core/Src/main.c ****           }
 459:Core/Src/main.c ****           UART_SendString(&huart3, "\r\n");
 460:Core/Src/main.c **** 
 461:Core/Src/main.c ****           // SLIP DECODE
 462:Core/Src/main.c ****           // SLIP special bytes:
 463:Core/Src/main.c ****           //   END     = 0xC0  -- marks start/end of packet
 464:Core/Src/main.c ****           //   ESC     = 0xDB  -- escape next byte
 465:Core/Src/main.c ****           //   ESC_END = 0xDC  -- escaped END (ESC + ESC_END => 0xC0)
 466:Core/Src/main.c ****           //   ESC_ESC = 0xDD  -- escaped ESC (ESC + ESC_ESC => 0xDB)
 467:Core/Src/main.c **** 
 468:Core/Src/main.c ****           #define SLIP_END     0xC0
 469:Core/Src/main.c ****           #define SLIP_ESC     0xDB
 470:Core/Src/main.c ****           #define SLIP_ESC_END 0xDC
 471:Core/Src/main.c ****           #define SLIP_ESC_ESC 0xDD
 472:Core/Src/main.c ****           #define SLIP_MAX_PACKET 250
 473:Core/Src/main.c **** 
 474:Core/Src/main.c ****           static uint8_t slip_buf[SLIP_MAX_PACKET];
 475:Core/Src/main.c ****           uint16_t slip_len = 0;
 476:Core/Src/main.c ****           uint8_t in_esc = 0;
 477:Core/Src/main.c ****           uint8_t slip_err = 0;
 478:Core/Src/main.c **** 
 479:Core/Src/main.c ****           for (uint16_t i = 0; i < lora_rx_len; i++) {
 480:Core/Src/main.c ****               uint8_t b = lora_rx_buf[i];
 481:Core/Src/main.c **** 
 482:Core/Src/main.c ****               if (b == SLIP_END) {
 483:Core/Src/main.c ****                   // END byte: if we have accumulated bytes, dispatch the packet
 484:Core/Src/main.c ****                   if (slip_len > 0) {
 485:Core/Src/main.c ****                       recv_lora_packet(slip_buf, (BufLen)slip_len);
 486:Core/Src/main.c ****                       //UART_SendString(&huart3, "JUST EXECUTED: \r\n");
 487:Core/Src/main.c ****                       slip_len = 0;
ARM GAS  /tmp/ccmBuZP2.s 			page 10


 488:Core/Src/main.c ****                       in_esc  = 0;
 489:Core/Src/main.c ****                       slip_err = 0;
 490:Core/Src/main.c ****                   }
 491:Core/Src/main.c ****                   // else: leading/trailing END byte, ignore (valid per RFC 1055)
 492:Core/Src/main.c ****               } else if (b == SLIP_ESC) {
 493:Core/Src/main.c ****                   in_esc = 1;
 494:Core/Src/main.c ****               } else if (in_esc) {
 495:Core/Src/main.c ****                   in_esc = 0;
 496:Core/Src/main.c ****                   if      (b == SLIP_ESC_END) b = SLIP_END;
 497:Core/Src/main.c ****                   else if (b == SLIP_ESC_ESC) b = SLIP_ESC;
 498:Core/Src/main.c ****                   else {
 499:Core/Src/main.c ****                       // Protocol violation — discard this packet
 500:Core/Src/main.c ****                       UART_SendString(&huart3, "SLIP ERR: bad escape\r\n");
 501:Core/Src/main.c ****                       slip_err = 1;
 502:Core/Src/main.c ****                       slip_len = 0;
 503:Core/Src/main.c ****                   }
 504:Core/Src/main.c ****                   if (!slip_err) {
 505:Core/Src/main.c ****                       if (slip_len < SLIP_MAX_PACKET) slip_buf[slip_len++] = b;
 506:Core/Src/main.c ****                       else {
 507:Core/Src/main.c ****                           UART_SendString(&huart3, "SLIP ERR: overflow\r\n");
 508:Core/Src/main.c ****                           slip_len = 0;
 509:Core/Src/main.c ****                           slip_err = 1;
 510:Core/Src/main.c ****                       }
 511:Core/Src/main.c ****                   }
 512:Core/Src/main.c ****               } else {
 513:Core/Src/main.c ****                   if (slip_len < SLIP_MAX_PACKET) slip_buf[slip_len++] = b;
 514:Core/Src/main.c ****                   else {
 515:Core/Src/main.c ****                       UART_SendString(&huart3, "SLIP ERR: overflow\r\n");
 516:Core/Src/main.c ****                       slip_len = 0;
 517:Core/Src/main.c ****                       slip_err = 1;
 518:Core/Src/main.c ****                   }
 519:Core/Src/main.c ****               }
 520:Core/Src/main.c ****           }
 521:Core/Src/main.c **** 
 522:Core/Src/main.c ****           // RESET BUFFER WHEN DONE
 523:Core/Src/main.c ****           lora_rx_len = 0;
 524:Core/Src/main.c ****           memset(lora_rx_buf, 0, sizeof(lora_rx_buf));
 525:Core/Src/main.c ****       }
