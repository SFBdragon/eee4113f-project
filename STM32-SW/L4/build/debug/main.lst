 476:Core/Src/main.c **** 
 477:Core/Src/main.c ****           // SLIP DECODE
 478:Core/Src/main.c ****           // SLIP special bytes:
 479:Core/Src/main.c ****           //   END     = 0xC0  -- marks start/end of packet
 480:Core/Src/main.c ****           //   ESC     = 0xDB  -- escape next byte
 481:Core/Src/main.c ****           //   ESC_END = 0xDC  -- escaped END (ESC + ESC_END => 0xC0)
 482:Core/Src/main.c ****           //   ESC_ESC = 0xDD  -- escaped ESC (ESC + ESC_ESC => 0xDB)
 483:Core/Src/main.c **** 
 484:Core/Src/main.c ****           #define SLIP_END     0xC0
 485:Core/Src/main.c ****           #define SLIP_ESC     0xDB
 486:Core/Src/main.c ****           #define SLIP_ESC_END 0xDC
 487:Core/Src/main.c ****           #define SLIP_ESC_ESC 0xDD
ARM GAS  /tmp/ccoVOuan.s 			page 10


 488:Core/Src/main.c ****           #define SLIP_MAX_PACKET 250
 489:Core/Src/main.c **** 
 490:Core/Src/main.c ****           static uint8_t slip_buf[SLIP_MAX_PACKET];
 491:Core/Src/main.c ****           uint16_t slip_len = 0;
 492:Core/Src/main.c ****           uint8_t in_esc = 0;
 493:Core/Src/main.c ****           uint8_t slip_err = 0;
 494:Core/Src/main.c **** 
 495:Core/Src/main.c ****           for (uint16_t i = 0; i < lora_rx_len; i++) {
 496:Core/Src/main.c ****               uint8_t b = lora_rx_buf[i];
 497:Core/Src/main.c **** 
 498:Core/Src/main.c ****               if (b == SLIP_END) {
 499:Core/Src/main.c ****                   // END byte: if we have accumulated bytes, dispatch the packet
 500:Core/Src/main.c ****                   if (slip_len > 0) {
 501:Core/Src/main.c ****                       recv_lora_packet(slip_buf, (BufLen)slip_len);
 502:Core/Src/main.c ****                       //UART_SendString(&huart3, "JUST EXECUTED: \r\n");
 503:Core/Src/main.c ****                       slip_len = 0;
 504:Core/Src/main.c ****                       in_esc  = 0;
 505:Core/Src/main.c ****                       slip_err = 0;
 506:Core/Src/main.c ****                   }
 507:Core/Src/main.c ****                   // else: leading/trailing END byte, ignore (valid per RFC 1055)
 508:Core/Src/main.c ****               } else if (b == SLIP_ESC) {
 509:Core/Src/main.c ****                   in_esc = 1;
 510:Core/Src/main.c ****               } else if (in_esc) {
 511:Core/Src/main.c ****                   in_esc = 0;
 512:Core/Src/main.c ****                   if      (b == SLIP_ESC_END) b = SLIP_END;
 513:Core/Src/main.c ****                   else if (b == SLIP_ESC_ESC) b = SLIP_ESC;
 514:Core/Src/main.c ****                   else {
 515:Core/Src/main.c ****                       // Protocol violation — discard this packet
 516:Core/Src/main.c ****                       UART_SendString(&huart3, "SLIP ERR: bad escape\r\n");
 517:Core/Src/main.c ****                       slip_err = 1;
 518:Core/Src/main.c ****                       slip_len = 0;
 519:Core/Src/main.c ****                   }
 520:Core/Src/main.c ****                   if (!slip_err) {
 521:Core/Src/main.c ****                       if (slip_len < SLIP_MAX_PACKET) slip_buf[slip_len++] = b;
 522:Core/Src/main.c ****                       else {
 523:Core/Src/main.c ****                           UART_SendString(&huart3, "SLIP ERR: overflow\r\n");
 524:Core/Src/main.c ****                           slip_len = 0;
 525:Core/Src/main.c ****                           slip_err = 1;
 526:Core/Src/main.c ****                       }
 527:Core/Src/main.c ****                   }
 528:Core/Src/main.c ****               } else {
 529:Core/Src/main.c ****                   if (slip_len < SLIP_MAX_PACKET) slip_buf[slip_len++] = b;
 530:Core/Src/main.c ****                   else {
 531:Core/Src/main.c ****                       UART_SendString(&huart3, "SLIP ERR: overflow\r\n");
 532:Core/Src/main.c ****                       slip_len = 0;
 533:Core/Src/main.c ****                       slip_err = 1;
 534:Core/Src/main.c ****                   }
 535:Core/Src/main.c ****               }
 536:Core/Src/main.c ****           }
 537:Core/Src/main.c **** 
 538:Core/Src/main.c ****           // RESET BUFFER WHEN DONE
 539:Core/Src/main.c ****           lora_rx_len = 0;
 540:Core/Src/main.c ****           memset(lora_rx_buf, 0, sizeof(lora_rx_buf));
 541:Core/Src/main.c ****       }
